    instruction: "Style IssueDetailDrawer layout, AI copilot block, description, subtasks, and comments using the Natural Tones design theme"
    replacement_infos {
      original_chunk {
        target_content: "  return (\n    <div className=\"fixed inset-y-0 right-0 z-40 w-full max-w-4xl bg-white shadow-2xl border-l border-slate-200 flex flex-col animate-in slide-in-from-right duration-250\">\n      \n      {/* Drawer Title & Actions Bar */}\n      <div className=\"px-6 py-4 border-b border-slate-200 bg-slate-900 text-white flex items-center justify-between\">\n        <div className=\"flex items-center gap-2 text-xs font-semibold tracking-wider text-slate-300\">\n          <span>{issue.projectId === \"proj-quantum\" ? \"QUANTUM ENGINE\" : \"APOLLO FRONTEND\"}</span>\n          <span>/</span>\n          <span className=\"text-white font-bold select-all\">{issue.key}</span>\n        </div>\n\n        <div className=\"flex items-center gap-4\">\n          <button\n            onClick={() => {\n              if (confirm(`Are you sure you want to delete ${issue.key}?`)) {\n                onDeleteIssue(issue.id);\n                onClose();\n              }\n            }}\n            className=\"p-2 hover:bg-slate-800 text-rose-400 hover:text-rose-300 rounded transition-colors\"\n            title=\"Delete Issue\"\n          >\n            <Trash className=\"w-4 h-4\" />\n          </button>\n          <button\n            onClick={onClose}\n            className=\"p-1.5 hover:bg-slate-800 rounded-full transition-colors text-slate-300 hover:text-white\"\n          >\n            <X className=\"w-5.5 h-5.5\" />\n          </button>\n        </div>\n      </div>\n\n      {/* Drawer Body Area (Split View) */}\n      <div className=\"flex-1 overflow-y-auto p-6 grid grid-cols-1 lg:grid-cols-12 gap-6 scrollbar-thin\">\n        \n        {/* LEFT PANEL - Primary content (8 columns) */}\n        <div className=\"lg:col-span-8 space-y-6\">\n          \n          {/* Summary / Title */}\n          <div>\n            <input\n              type=\"text\"\n              value={summary}\n              onChange={(e) => setSummary(e.target.value)}\n              onBlur={handleSummaryBlur}\n              className=\"w-full text-xl font-bold text-slate-900 border-0 border-b border-transparent hover:border-slate-200 focus:border-blue-500 focus:ring-0 px-1 py-1 transition-all\"\n            />\n          </div>\n\n          {/* AI AGENT COMPASS (Agile Assistant Controls) */}\n          <div className=\"bg-blue-50 border border-blue-200/60 rounded-xl p-4.5 space-y-3.5\">\n            <h4 className=\"text-xs font-bold text-blue-900 flex items-center gap-1.5 uppercase tracking-wider\">\n              <Sparkles className=\"w-4 h-4 text-blue-600 animate-pulse\" /> AI Agile Copilot Actions\n            </h4>\n\n            <div className=\"flex flex-wrap gap-2.5\">\n              <button\n                disabled={aiLoading.desc}\n                onClick={triggerAIDescription}\n                className=\"flex items-center gap-1.5 px-3 py-1.5 bg-blue-600 hover:bg-blue-700 disabled:bg-blue-300 text-white font-bold text-xs rounded transition-all shadow-2xs\"\n              >\n                {aiLoading.desc ? \"Drafting Description...\" : \"AI Optimize Description\"}\n              </button>\n\n              <button\n                disabled={aiLoading.breakdown}\n                onClick={triggerAIBreakdown}\n                className=\"flex items-center gap-1.5 px-3 py-1.5 bg-slate-900 hover:bg-slate-800 disabled:bg-slate-400 text-white font-bold text-xs rounded transition-all shadow-2xs\"\n              >\n                {aiLoading.breakdown ? \"Analyzing...\" : \"AI Subtask Breakdown\"}\n              </button>\n\n              <button\n                disabled={aiLoading.estimate}\n                onClick={triggerAIEstimation}\n                className=\"flex items-center gap-1.5 px-3 py-1.5 bg-white border border-blue-300 text-blue-700 hover:bg-blue-100/50 disabled:bg-slate-100 font-bold text-xs rounded transition-all\"\n              >\n                {aiLoading.estimate ? \"Calculating...\" : \"AI Estimate Points\"}\n              </button>\n            </div>\n\n            {/* AI Estimation Result Panel */}\n            {aiEstimationResult && (\n              <div className=\"bg-white border border-blue-100 rounded-lg p-3 text-xs shadow-xs animate-in slide-in-from-top-1\">\n                <div className=\"flex items-center justify-between mb-1.5\">\n                  <span className=\"font-bold text-blue-900\">\n                    AI Estimated Value: <strong className=\"text-sm text-blue-600\">{aiEstimationResult.points} SP</strong>\n                  </span>\n                  <button\n                    onClick={applyAIEstimation}\n                    className=\"px-2.5 py-1 bg-emerald-600 hover:bg-emerald-700 text-white font-bold rounded\"\n                  >\n                    Apply Estimate\n                  </button>\n                </div>\n                <p className=\"text-slate-600 leading-relaxed italic\">\n                  Rationale: \"{aiEstimationResult.rationale}\"\n                </p>\n              </div>\n            )}\n          </div>\n\n          {/* Issue Description Area */}\n          <div>\n            <div className=\"flex items-center justify-between mb-2\">\n              <label className=\"text-xs font-bold text-slate-500 uppercase tracking-wider\">\n                Description\n              </label>\n              {!isEditingDesc ? (\n                <button\n                  onClick={() => setIsEditingDesc(true)}\n                  className=\"flex items-center gap-1 text-xs text-blue-600 hover:text-blue-800 font-semibold\"\n                >\n                  <Edit className=\"w-3.5 h-3.5\" /> Edit Markdown\n                </button>\n              ) : (\n                <div className=\"flex gap-2\">\n                  <button\n                    onClick={handleDescSave}\n                    className=\"flex items-center gap-1 text-xs text-emerald-600 hover:text-emerald-800 font-bold\"\n                  >\n                    <Check className=\"w-3.5 h-3.5\" /> Save\n                  </button>\n                  <button\n                    onClick={() => {\n                      setDescription(issue.description);\n                      setIsEditingDesc(false);\n                    }}\n                    className=\"text-xs text-slate-500 hover:text-slate-800 font-semibold\"\n                  >\n                    Cancel\n                  </button>\n                </div>\n              )}\n            </div>\n\n            {isEditingDesc ? (\n              <textarea\n                value={description}\n                onChange={(e) => setDescription(e.target.value)}\n                className=\"w-full h-48 px-3 py-2 text-xs border border-slate-200 rounded-md font-mono focus:ring-1 focus:ring-blue-500 bg-slate-50\"\n                placeholder=\"Use Markdown formats: # Header, **bold**, - list...\"\n              />\n            ) : (\n              <div className=\"prose prose-sm prose-slate max-w-none bg-slate-50 rounded-lg p-4 border border-slate-100 min-h-[100px] text-slate-800 text-xs leading-relaxed space-y-2 whitespace-pre-wrap font-sans\">\n                {description || (\n                  <span className=\"text-slate-400 italic\">No description provided. Click AI Optimize or Edit to begin writing.</span>\n                )}\n              </div>\n            )}\n          </div>\n\n          {/* Subtasks Checklist */}\n          <div>\n            <div className=\"flex items-center justify-between mb-2.5\">\n              <label className=\"text-xs font-bold text-slate-500 uppercase tracking-wider\">\n                Sub-tasks Checklist\n              </label>\n              {issue.subtasks.length > 0 && (\n                <span className=\"text-xs font-bold text-slate-600\">\n                  {Math.round((issue.subtasks.filter(s => s.completed).length / issue.subtasks.length) * 100)}% Complete\n                </span>\n              )}\n            </div>\n\n            {/* Subtask items checklist */}\n            <div className=\"space-y-1.5 mb-3\">\n              {issue.subtasks.map((st) => (\n                <div key={st.id} className=\"flex items-center justify-between p-2 bg-slate-50 hover:bg-slate-100 border border-slate-100 rounded-md group text-xs\">\n                  <div className=\"flex items-center gap-2.5 min-w-0 flex-1\">\n                    <input\n                      type=\"checkbox\"\n                      checked={st.completed}\n                      onChange={(e) => handleToggleSubtask(st.id, e.target.checked)}\n                      className=\"w-4 h-4 text-blue-600 rounded focus:ring-blue-500 focus:ring-2 border-slate-300\"\n                    />\n                    <span className={`text-slate-800 truncate ${st.completed ? \"line-through text-slate-400\" : \"\"}`}>\n                      {st.title}\n                    </span>\n                  </div>\n                  <button\n                    onClick={() => handleDeleteSubtask(st.id)}\n                    className=\"opacity-0 group-hover:opacity-100 text-rose-500 hover:text-rose-700 px-1 transition-opacity\"\n                    title=\"Delete subtask\"\n                  >\n                    Delete\n                  </button>\n                </div>\n              ))}\n            </div>\n\n            {/* Inline Subtask input form */}\n            <div className=\"flex items-center gap-2\">\n              <input\n                type=\"text\"\n                placeholder=\"Add sub-task...\"\n                value={newSubtask}\n                onChange={(e) => setNewSubtask(e.target.value)}\n                onKeyDown={(e) => {\n                  if (e.key === \"Enter\") handleAddSubtask();\n                }}\n                className=\"flex-1 px-3 py-1.5 text-xs border border-slate-200 rounded-md\"\n              />\n              <button\n                onClick={handleAddSubtask}\n                className=\"px-3 py-1.5 bg-slate-900 hover:bg-slate-800 text-white font-bold rounded text-xs\"\n              >\n                Add\n              </button>\n            </div>\n          </div>\n\n          {/* Comments Thread Section */}\n          <div className=\"border-t border-slate-100 pt-6\">\n            <h4 className=\"text-xs font-bold text-slate-500 uppercase tracking-wider mb-4\">\n              Activity & Comments ({issue.comments.length})\n            </h4>\n\n            {/* Add Comment Input form */}\n            <form onSubmit={handleAddCommentSubmit} className=\"flex items-start gap-3 mb-6\">\n              <img\n                src=\"https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=150\"\n                alt=\"user avatar\"\n                className=\"w-8 h-8 rounded-full ring-1 ring-slate-200 object-cover mt-0.5\"\n                referrerPolicy=\"no-referrer\"\n              />\n              <div className=\"flex-1 space-y-2\">\n                <input\n                  type=\"text\"\n                  placeholder=\"Ask a question or provide design logs...\"\n                  value={newComment}\n                  onChange={(e) => setNewComment(e.target.value)}\n                  className=\"w-full px-3.5 py-2 text-xs border border-slate-200 rounded-md focus:ring-1 focus:ring-blue-500\"\n                />\n                <button\n                  type=\"submit\"\n                  className=\"px-4 py-1.5 bg-slate-900 hover:bg-slate-800 text-white font-semibold text-xs rounded shadow-2xs\"\n                >\n                  Save Comment\n                </button>\n              </div>\n            </form>\n\n            {/* List of comments */}\n            <div className=\"space-y-4\">\n              {issue.comments.map((comment) => (\n                <div key={comment.id} className=\"flex items-start gap-3 text-xs p-3.5 bg-slate-50/50 rounded-lg border border-slate-100 hover:border-slate-200 transition-all group\">\n                  <img\n                    src={comment.avatar}\n                    alt={comment.author}\n                    className=\"w-8 h-8 rounded-full ring-1 ring-slate-200 object-cover shrink-0\"\n                    referrerPolicy=\"no-referrer\"\n                  />\n                  <div className=\"flex-1 space-y-1\">\n                    <div className=\"flex items-center justify-between\">\n                      <div className=\"space-x-2\">\n                        <strong className=\"font-bold text-slate-800\">{comment.author}</strong>\n                        <span className=\"text-[10px] text-slate-400\">\n                          {new Date(comment.createdAt).toLocaleString()}\n                        </span>\n                      </div>\n                      <button\n                        onClick={() => handleDeleteComment(comment.id)}\n                        className=\"opacity-0 group-hover:opacity-100 text-[10px] text-rose-500 hover:text-rose-700 transition-all\"\n                      >\n                        Delete\n                      </button>\n                    </div>\n                    <p className=\"text-slate-600 leading-relaxed font-sans\">{comment.text}</p>\n                  </div>\n                </div>\n              ))}\n            </div>\n          </div>\n\n        </div>"
        replacement_content: "  return (\n    <div className=\"fixed inset-y-0 right-0 z-40 w-full max-w-4xl bg-natural-bg shadow-2xl border-l border-natural-border flex flex-col animate-in slide-in-from-right duration-250\">\n      \n      {/* Drawer Title & Actions Bar */}\n      <div className=\"px-6 py-4.5 border-b border-natural-border bg-natural-sidebar text-natural-text-deep flex items-center justify-between\">\n        <div className=\"flex items-center gap-2 text-xs font-bold tracking-widest text-natural-text-neutral\">\n          <span>{issue.projectId === \"proj-quantum\" ? \"QUANTUM ENGINE\" : \"APOLLO FRONTEND\"}</span>\n          <span className=\"text-natural-border font-normal\">/</span>\n          <span className=\"text-natural-primary font-black select-all\">{issue.key}</span>\n        </div>\n\n        <div className=\"flex items-center gap-4\">\n          <button\n            onClick={() => {\n              if (confirm(`Are you sure you want to delete ${issue.key}?`)) {\n                onDeleteIssue(issue.id);\n                onClose();\n              }\n            }}\n            className=\"p-2 hover:bg-natural-hover-bg text-rose-600 hover:text-rose-700 rounded-full transition-colors\"\n            title=\"Delete Issue\"\n          >\n            <Trash className=\"w-4 h-4\" />\n          </button>\n          <button\n            onClick={onClose}\n            className=\"p-1.5 hover:bg-natural-hover-bg text-natural-text-neutral hover:text-natural-text-deep rounded-full transition-colors\"\n          >\n            <X className=\"w-5.5 h-5.5\" />\n          </button>\n        </div>\n      </div>\n\n      {/* Drawer Body Area (Split View) */}\n      <div className=\"flex-1 overflow-y-auto p-6 grid grid-cols-1 lg:grid-cols-12 gap-6 scrollbar-thin\">\n        \n        {/* LEFT PANEL - Primary content (8 columns) */}\n        <div className=\"lg:col-span-8 space-y-6\">\n          \n          {/* Summary / Title */}\n          <div>\n            <input\n              type=\"text\"\n              value={summary}\n              onChange={(e) => setSummary(e.target.value)}\n              onBlur={handleSummaryBlur}\n              className=\"w-full text-xl font-bold text-natural-text-deep border-0 border-b border-transparent hover:border-natural-border focus:border-natural-primary focus:ring-0 px-2 py-1.5 transition-all bg-transparent rounded-xl focus:bg-white\"\n            />\n          </div>\n\n          {/* AI AGENT COMPASS (Agile Assistant Controls) */}\n          <div className=\"bg-natural-primary/5 border border-natural-primary/15 rounded-2xl p-5 space-y-4\">\n            <h4 className=\"text-xs font-bold text-natural-primary flex items-center gap-1.5 uppercase tracking-wider\">\n              <Sparkles className=\"w-4 h-4 text-natural-primary animate-pulse\" /> AI Agile Copilot Actions\n            </h4>\n\n            <div className=\"flex flex-wrap gap-2.5\">\n              <button\n                disabled={aiLoading.desc}\n                onClick={triggerAIDescription}\n                className=\"flex items-center gap-1.5 px-4 py-2 bg-natural-primary hover:bg-natural-primary-hover disabled:bg-natural-border disabled:text-natural-text-light text-white font-bold text-xs rounded-full transition-all shadow-xs cursor-pointer\"\n              >\n                {aiLoading.desc ? \"Drafting Description...\" : \"AI Optimize Description\"}\n              </button>\n\n              <button\n                disabled={aiLoading.breakdown}\n                onClick={triggerAIBreakdown}\n                className=\"flex items-center gap-1.5 px-4 py-2 bg-natural-accent hover:bg-natural-accent-dark disabled:bg-natural-border disabled:text-natural-text-light text-white font-bold text-xs rounded-full transition-all shadow-xs cursor-pointer\"\n              >\n                {aiLoading.breakdown ? \"Analyzing...\" : \"AI Subtask Breakdown\"}\n              </button>\n\n              <button\n                disabled={aiLoading.estimate}\n                onClick={triggerAIEstimation}\n                className=\"flex items-center gap-1.5 px-4 py-2 bg-white border border-natural-border text-natural-text-deep hover:bg-natural-hover-bg disabled:bg-slate-100 font-bold text-xs rounded-full transition-all cursor-pointer shadow-2xs\"\n              >\n                {aiLoading.estimate ? \"Calculating...\" : \"AI Estimate Points\"}\n              </button>\n            </div>\n\n            {/* AI Estimation Result Panel */}\n            {aiEstimationResult && (\n              <div className=\"bg-white border border-natural-border rounded-xl p-4.5 text-xs shadow-2xs animate-in slide-in-from-top-1\">\n                <div className=\"flex items-center justify-between mb-2\">\n                  <span className=\"font-bold text-natural-text-deep\">\n                    AI Estimated Value: <strong className=\"text-sm text-natural-primary\">{aiEstimationResult.points} SP</strong>\n                  </span>\n                  <button\n                    onClick={applyAIEstimation}\n                    className=\"px-3.5 py-1.5 bg-natural-primary hover:bg-natural-primary-hover text-white font-bold rounded-full text-xs shadow-xs transition-colors\"\n                  >\n                    Apply Estimate\n                  </button>\n                </div>\n                <p className=\"text-natural-text-neutral leading-relaxed italic\">\n                  Rationale: \"{aiEstimationResult.rationale}\"\n                </p>\n              </div>\n            )}\n          </div>\n\n          {/* Issue Description Area */}\n          <div>\n            <div className=\"flex items-center justify-between mb-2\">\n              <label className=\"text-xs font-bold text-natural-text-neutral uppercase tracking-wider\">\n                Description\n              </label>\n              {!isEditingDesc ? (\n                <button\n                  onClick={() => setIsEditingDesc(true)}\n                  className=\"flex items-center gap-1 text-xs text-natural-primary hover:text-natural-primary-hover font-semibold transition-colors\"\n                >\n                  <Edit className=\"w-3.5 h-3.5\" /> Edit Markdown\n                </button>\n              ) : (\n                <div className=\"flex gap-2\">\n                  <button\n                    onClick={handleDescSave}\n                    className=\"flex items-center gap-1 text-xs text-natural-primary hover:text-natural-primary-hover font-bold transition-colors\"\n                  >\n                    <Check className=\"w-3.5 h-3.5\" /> Save\n                  </button>\n                  <button\n                    onClick={() => {\n                      setDescription(issue.description);\n                      setIsEditingDesc(false);\n                    }}\n                    className=\"text-xs text-natural-text-neutral hover:text-natural-text-deep font-semibold transition-colors\"\n                  >\n                    Cancel\n                  </button>\n                </div>\n              )}\n            </div>\n\n            {isEditingDesc ? (\n              <textarea\n                value={description}\n                onChange={(e) => setDescription(e.target.value)}\n                className=\"w-full h-48 px-4 py-3 text-xs border border-natural-border rounded-2xl font-mono focus:ring-1 focus:ring-natural-primary focus:outline-hidden bg-white text-natural-text-deep\"\n                placeholder=\"Use Markdown formats: # Header, **bold**, - list...\"\n              />\n            ) : (\n              <div className=\"prose prose-sm prose-slate max-w-none bg-white rounded-2xl p-5 border border-natural-border min-h-[120px] text-natural-text-deep text-xs leading-relaxed space-y-2 whitespace-pre-wrap font-sans shadow-2xs\">\n                {description || (\n                  <span className=\"text-natural-text-light italic\">No description provided. Click AI Optimize or Edit to begin writing.</span>\n                )}\n              </div>\n            )}\n          </div>\n\n          {/* Subtasks Checklist */}\n          <div>\n            <div className=\"flex items-center justify-between mb-2.5\">\n              <label className=\"text-xs font-bold text-natural-text-neutral uppercase tracking-wider\">\n                Sub-tasks Checklist\n              </label>\n              {issue.subtasks.length > 0 && (\n                <span className=\"text-xs font-bold text-natural-text-deep bg-natural-sidebar px-2 py-0.5 rounded-full border border-natural-border text-[11px]\">\n                  {Math.round((issue.subtasks.filter(s => s.completed).length / issue.subtasks.length) * 100)}% Complete\n                </span>\n              )}\n            </div>\n\n            {/* Subtask items checklist */}\n            <div className=\"space-y-1.5 mb-3\">\n              {issue.subtasks.map((st) => (\n                <div key={st.id} className=\"flex items-center justify-between p-2.5 bg-white hover:bg-natural-hover-bg border border-natural-border/60 rounded-xl group text-xs transition-colors\">\n                  <div className=\"flex items-center gap-2.5 min-w-0 flex-1\">\n                    <input\n                      type=\"checkbox\"\n                      checked={st.completed}\n                      onChange={(e) => handleToggleSubtask(st.id, e.target.checked)}\n                      className=\"w-4 h-4 text-natural-primary rounded border-natural-border focus:ring-natural-primary/20 focus:ring-2\"\n                    />\n                    <span className={`text-natural-text-deep font-semibold truncate ${st.completed ? \"line-through text-natural-text-light\" : \"\"}`}>\n                      {st.title}\n                    </span>\n                  </div>\n                  <button\n                    onClick={() => handleDeleteSubtask(st.id)}\n                    className=\"opacity-0 group-hover:opacity-100 text-rose-600 hover:text-rose-700 font-semibold px-2 transition-opacity\"\n                    title=\"Delete subtask\"\n                  >\n                    Delete\n                  </button>\n                </div>\n              ))}\n            </div>\n\n            {/* Inline Subtask input form */}\n            <div className=\"flex items-center gap-2\">\n              <input\n                type=\"text\"\n                placeholder=\"Add sub-task...\"\n                value={newSubtask}\n                onChange={(e) => setNewSubtask(e.target.value)}\n                onKeyDown={(e) => {\n                  if (e.key === \"Enter\") handleAddSubtask();\n                }}\n                className=\"flex-1 px-3.5 py-2 text-xs border border-natural-border bg-white rounded-xl focus:ring-1 focus:ring-natural-primary focus:outline-hidden text-natural-text-deep\"\n              />\n              <button\n                onClick={handleAddSubtask}\n                className=\"px-4 py-2 bg-natural-primary hover:bg-natural-primary-hover text-white font-bold rounded-full text-xs shadow-2xs transition-all\"\n              >\n                Add\n              </button>\n            </div>\n          </div>\n\n          {/* Comments Thread Section */}\n          <div className=\"border-t border-natural-border pt-6\">\n            <h4 className=\"text-xs font-bold text-natural-text-neutral uppercase tracking-wider mb-4\">\n              Activity & Comments ({issue.comments.length})\n            </h4>\n\n            {/* Add Comment Input form */}\n            <form onSubmit={handleAddCommentSubmit} className=\"flex items-start gap-3 mb-6\">\n              <img\n                src=\"https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=150\"\n                alt=\"user avatar\"\n                className=\"w-8 h-8 rounded-full ring-1 ring-natural-border object-cover mt-0.5\"\n                referrerPolicy=\"no-referrer\"\n              />\n              <div className=\"flex-1 space-y-2\">\n                <input\n                  type=\"text\"\n                  placeholder=\"Ask a question or provide design logs...\"\n                  value={newComment}\n                  onChange={(e) => setNewComment(e.target.value)}\n                  className=\"w-full px-3.5 py-2.5 text-xs border border-natural-border bg-white rounded-xl focus:ring-1 focus:ring-natural-primary focus:outline-hidden text-natural-text-deep placeholder:text-natural-text-light shadow-2xs\"\n                />\n                <button\n                  type=\"submit\"\n                  className=\"px-4 py-2 bg-natural-primary hover:bg-natural-primary-hover text-white font-bold text-xs rounded-full transition-all shadow-xs\"\n                >\n                  Save Comment\n                </button>\n              </div>\n            </form>\n\n            {/* List of comments */}\n            <div className=\"space-y-4\">\n              {issue.comments.map((comment) => (\n                <div key={comment.id} className=\"flex items-start gap-3 text-xs p-4 bg-white rounded-xl border border-natural-border/70 hover:border-natural-primary/35 transition-all group\">\n                  <img\n                    src={comment.avatar}\n                    alt={comment.author}\n                    className=\"w-8 h-8 rounded-full ring-1 ring-natural-border object-cover shrink-0\"\n                    referrerPolicy=\"no-referrer\"\n                  />\n                  <div className=\"flex-1 space-y-1\">\n                    <div className=\"flex items-center justify-between\">\n                      <div className=\"space-x-2\">\n                        <strong className=\"font-bold text-natural-text-deep\">{comment.author}</strong>\n                        <span className=\"text-[10px] text-natural-text-light font-medium\">\n                          {new Date(comment.createdAt).toLocaleString()}\n                        </span>\n                      </div>\n                      <button\n                        onClick={() => handleDeleteComment(comment.id)}\n                        className=\"opacity-0 group-hover:opacity-100 text-[10px] text-rose-600 hover:text-rose-700 font-semibold transition-all\"\n                      >\n                        Delete\n                      </button>\n                    </div>\n                    <p className=\"text-natural-text-neutral font-medium leading-relaxed font-sans\">{comment.text}</p>\n                  </div>\n                </div>\n              ))}\n            </div>\n          </div>\n\n        </div>"
      }
      num_matches: 1
    }
  }
}
