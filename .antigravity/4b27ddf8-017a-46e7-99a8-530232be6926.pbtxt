        target_content: "  return (\n    <div className=\"flex h-screen w-screen overflow-hidden bg-white text-slate-800 font-sans\" id=\"main-app\">\n      \n      {/* LEFT NAVIGATION COLUMN (SIDEBAR) */}\n      <div className=\"w-64 bg-slate-900 text-white flex flex-col justify-between shrink-0 border-r border-slate-800\">\n        \n        <div>\n          {/* Logo segment */}\n          <div className=\"px-6 py-4 border-b border-slate-800 flex items-center justify-between\">\n            <div className=\"flex items-center gap-2.5\">\n              <div className=\"p-1.5 bg-blue-600 rounded text-white font-extrabold flex items-center justify-center\">\n                <LayoutGrid className=\"w-5 h-5\" />\n              </div>\n              <span className=\"font-extrabold text-sm tracking-wide bg-gradient-to-r from-white to-slate-400 bg-clip-text text-transparent\">\n                Jira Workspace\n              </span>\n            </div>\n          </div>\n\n          {/* Project Selector Segment */}\n          <div className=\"px-4 py-4 border-b border-slate-800 space-y-2\">\n            <div className=\"flex items-center justify-between text-[10px] font-bold text-slate-400 uppercase px-2 tracking-wider\">\n              <span>Agile Project</span>\n              <button\n                onClick={() => setIsNewProjectOpen(true)}\n                className=\"hover:text-white transition-colors flex items-center gap-0.5 text-xs font-bold text-blue-400\"\n                title=\"Create New Project\"\n              >\n                <Plus className=\"w-3.5 h-3.5\" /> Project\n              </button>\n            </div>\n\n            {currentProject ? (\n              <div className=\"relative group px-2 py-2.5 bg-slate-800/60 hover:bg-slate-800 rounded-lg border border-slate-700/50 flex items-center justify-between transition-all\">\n                <div className=\"flex items-center gap-2.5\">\n                  <div className=\"w-7 h-7 bg-blue-500 rounded font-bold text-xs text-white flex items-center justify-center\">\n                    {currentProject.key}\n                  </div>\n                  <div className=\"min-w-0\">\n                    <span className=\"block font-semibold text-xs text-white truncate\">{currentProject.name}</span>\n                    <span className=\"block text-[9px] text-slate-400 tracking-wider font-semibold\">Key: {currentProject.key}</span>\n                  </div>\n                </div>\n\n                {/* Switcher selector */}\n                <select\n                  value={activeProjectId}\n                  onChange={(e) => setActiveProjectId(e.target.value)}\n                  className=\"absolute inset-0 opacity-0 w-full cursor-pointer h-full\"\n                  title=\"Switch Project Workspace\"\n                >\n                  {projects.map((p) => (\n                    <option key={p.id} value={p.id}>\n                      {p.name} ({p.key})\n                    </option>\n                  ))}\n                </select>\n                <ChevronDown className=\"w-4 h-4 text-slate-400\" />\n              </div>\n            ) : (\n              <p className=\"text-xs text-slate-400 px-2\">No projects configured</p>\n            )}\n          </div>\n\n          {/* Tab Navigation items */}\n          <nav className=\"p-3 space-y-1\">\n            <button\n              onClick={() => setActiveTab(\"board\")}\n              className={`w-full flex items-center gap-3 px-3 py-2 text-xs font-bold rounded-md transition-colors ${\n                activeTab === \"board\"\n                  ? \"bg-blue-600 text-white\"\n                  : \"text-slate-300 hover:bg-slate-800 hover:text-white\"\n              }`}\n            >\n              <LayoutGrid className=\"w-4 h-4\" /> Active Sprint Board\n            </button>\n\n            <button\n              onClick={() => setActiveTab(\"backlog\")}\n              className={`w-full flex items-center gap-3 px-3 py-2 text-xs font-bold rounded-md transition-colors ${\n                activeTab === \"backlog\"\n                  ? \"bg-blue-600 text-white\"\n                  : \"text-slate-300 hover:bg-slate-800 hover:text-white\"\n              }`}\n            >\n              <Database className=\"w-4 h-4\" /> Backlog Planner\n            </button>\n\n            <button\n              onClick={() => setActiveTab(\"copilot\")}\n              className={`w-full flex items-center gap-3 px-3 py-2 text-xs font-bold rounded-md transition-colors ${\n                activeTab === \"copilot\"\n                  ? \"bg-blue-600 text-white\"\n                  : \"text-slate-300 hover:bg-slate-800 hover:text-white\"\n              }`}\n            >\n              <Sparkles className=\"w-4 h-4 text-amber-400 fill-amber-400/20\" /> Agile AI Copilot\n            </button>\n\n            <button\n              onClick={() => setActiveTab(\"insights\")}\n              className={`w-full flex items-center gap-3 px-3 py-2 text-xs font-bold rounded-md transition-colors ${\n                activeTab === \"insights\"\n                  ? \"bg-blue-600 text-white\"\n                  : \"text-slate-300 hover:bg-slate-800 hover:text-white\"\n              }`}\n            >\n              <BarChart2 className=\"w-4 h-4\" /> Reports & Insights\n            </button>\n          </nav>\n        </div>\n\n        {/* Footer info segment */}\n        <div className=\"p-4 border-t border-slate-800 bg-slate-950/45\">\n          <div className=\"flex items-center gap-3\">\n            <img\n              src=\"https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=150\"\n              alt=\"Nithish profile\"\n              className=\"w-8.5 h-8.5 rounded-full ring-1 ring-slate-700 object-cover\"\n              referrerPolicy=\"no-referrer\"\n            />\n            <div className=\"min-w-0\">\n              <span className=\"block text-xs font-bold text-white truncate\">Nithish Reddy</span>\n 