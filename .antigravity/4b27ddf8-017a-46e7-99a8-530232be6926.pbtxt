    replacement_chunks {
      target_content: "  return (\n    <div className=\"flex-1 overflow-y-auto bg-slate-50 scrollbar-thin\" id=\"ai-copilot-workspace\">\n      {/* Page Header */}\n      <div className=\"px-6 py-4 bg-white border-b border-slate-200 shadow-xs\">\n        <div className=\"text-xs font-semibold text-blue-600 uppercase tracking-wider flex items-center gap-1\">\n          <Sparkles className=\"w-3.5 h-3.5 animate-pulse\" /> Agile AI Copilot\n        </div>\n        <h1 className=\"text-2xl font-bold text-slate-900 tracking-tight\">\n          Scrum AI Assistant & Roadmapper\n        </h1>\n        <p className=\"text-xs text-slate-500 mt-1\">\n          Plan entire sprints automatically or run an agile audit on your active Kanban board status to detect blockers.\n        </p>\n      </div>Description\n\n      <div className=\"p-6 max-w-5xl mx-auto w-full grid grid-cols-1 md:grid-cols-12 gap-6\">\n        \n        {/* LEFT COLUMN: Roadmap generator (7 columns) */}\n        <div className=\"md:col-span-7 space-y-6\">\n          \n          {/* Form */}\n          <div className=\"bg-white rounded-xl border border-slate-200 p-5 shadow-xs\">\n            <h3 className=\"font-bold text-slate-950 mb-1 flex items-center gap-1.5 text-sm\">\n              <Sparkles className=\"w-4.5 h-4.5 text-blue-600\" /> Sprint Goals AI Roadmapper\n            </h3>\n            <p className=\"text-xs text-slate-500 mb-4\">\n              Type in a product requirement or milestone, and the copilot will automatically generate 4 to 7 structured Epics, Stories, and Bugs.\n            </p>\n \n            <form onSubmit={handleGenerateRoadmap} className=\"space-y-4\">\n              <div>\n                <textarea\n                  value={goalInput}\n                  onChange={(e) => setGoalInput(e.target.value)}\n                  placeholder=\"e.g. Integrate a Stripe checkout subscription system supporting monthly and annual billing with a graceful loading portal\"\n                  required\n                  rows={3}\n                  className=\"w-full px-3.5 py-2 text-xs border border-slate-200 rounded-lg focus:ring-1 focus:ring-blue-500 bg-slate-50/50\"\n                />\n              </div>\n\n              <div className=\"flex justify-end\">\n                <button\n                  type=\"submit\"\n                  disabled={loading}\n                  className=\"px-4 py-2 bg-blue-600 hover:bg-blue-700 disabled:bg-blue-300 text-white font-bold text-xs rounded-lg shadow-xs transition-colors flex items-center gap-1.5\"\n                >\n                  <Sparkles className=\"w-3.5 h-3.5\" /> {loading ? \"Generating Roadmap...\" : \"Generate Proposed Backlog\"}\n                </button>\n              </div>\n            </form>\n          </div>\n\n          {/* Proposal loading status */}\n          {loading && (\n            <div className=\"bg-white rounded-xl border border-slate-200 p-8 text-center shadow-xs animate-pulse\">\n              <RefreshCw className=\"w-8 h-8 text-blue-600 animate-spin mx-auto mb-3\" />\n              <h4 className=\"font-bold text-slate-800 text-sm\">Jira AI Agent Thinking...</h4>\n              <p className=\"text-xs text-slate-500 mt-1.5\">{loadingStep}</p>\n            </div>\n          )}\n\n          {/* Proposal Review List */}\n          {proposedIssues.length > 0 && (\n            <div className=\"bg-white rounded-xl border border-slate-200 overflow-hidden shadow-sm animate-in fade-in duration-300\">\n              <div className=\"px-5 py-3.5 bg-slate-900 text-white flex items-center justify-between\">\n                <div>\n                  <h4 className=\"font-bold text-xs uppercase tracking-wider text-blue-400\">Review Proposed Roadmap</h4>\n                  <p className=\"text-[10px] text-slate-300\">Generated {proposedIssues.length} issues for your backlog</p>\n                </div>\n                <button\n                  onClick={handleBulkImport}\n                  className=\"px-4 py-1.5 bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs rounded-md shadow-xs transition-colors flex items-center gap-1\"\n                >\n                  Import All to Backlog <ArrowRight className=\"w-3.5 h-3.5\" />\n                </button>\n              </div>\n\n              <div className=\"divide-y divide-slate-100 max-h-[480px] overflow-y-auto scrollbar-thin\">\n                {proposedIssues.map((issue, index) => (\n                  <div key={index} className=\"p-4 bg-white hover:bg-slate-50/50 transition-colors\">\n                    <div className=\"flex items-start justify-between gap-3 mb-1.5\">\n                      <div className=\"flex items-center gap-2\">\n                        <span>{getIssueTypeIcon(issue.issueType)}</span>\n                        <span className=\"text-[10px] font-bold text-slate-400 uppercase tracking-widest\">{issue.issueType}</span>\n                        <h5 className=\"font-semibold text-slate-900 text-xs\">{issue.summary}</h5>\n                      </div>\n                      <span className={`px-2 py-0.5 rounded border font-bold text-[9px] ${getPriorityBadgeColor(issue.priority)}`}>\n                        {issue.priority}\n                      </span>\n                    </div>\n\n                    <p className=\"text-xs text-slate-600 leading-relaxed pl-6 italic mb-2\">\n                      {issue.description}\n                    </p>\n\n                    <div className=\"flex items-center gap-3 pl-6 text-[10px] text-slate-400\">\n                      <span>Estimated Points: <strong className=\"text-slate-700 font-bold\">{issue.storyPoints} SP</strong></span>\n                      <span>\342\200\242</span>\n                      <span>Initial Status: <strong className=\"text-slate-700 font-bold\">{issue.initialStatus}</strong></span>\n                    </div>\n                  </div>\n                ))}\n              </div>\n            </div>\n          )}\n\n        </div>\n\n        {/* RIGHT COLUMN: PM Health check & standup assistant (5 columns) */}\n        <div className=\"md:col-span-5 space-y-6\">\n          \n          <div className=\"bg-white rounded-xl border border-slate-200 p-5 shadow-xs\">\n            <h3 className=\"font-bold text-slate-950 mb-1 flex items-center gap-1.5 text-sm\">\n              <Clipboard className=\"w-4.5 h-4.5 text-blue-600\" /> Scrum Coach Audit\n            </h3>\n            <p className=\"text-xs text-slate-500 mb-4\">\n              Initiate a live project health check. The Scrum Coach AI will analyze active story metrics, identify unassigned tickets, and highlight workload bottlenecks.\n            </p>\n\n            <button\n              onClick={handleHealthCheck}\n              disabled={checkingHealth}\n              className=\"w-full py-2 bg-slate-900 hover:bg-slate-800 text-white font-bold text-xs rounded-lg shadow-xs transition-colors\"\n            >\n              {checkingHealth ? \"Running Heuristics Audit...\" : \"Run Scrum Health Check\"}\n            </button>\n          </div>\n\n          {/* Heuristic Audit Output */}\n          {healthFeedback && (\n            <div className=\"bg-slate-900 text-white rounded-xl p-5 shadow-lg border border-slate-800 animate-in slide-in-from-bottom-2 duration-300\">\n              <div className=\"prose prose-invert prose-xs leading-relaxed space-y-3 font-mono text-xs\">\n                {/* Visual markdown formatter */}\n                {healthFeedback.split(\"\\n\").map((line, idx) => {\n                  if (line.startsWith(\"### \")) {\n                    return <h3 key={idx} className=\"text-sm font-bold text-blue-400 mt-4 first:mt-0 pb-1 border-b border-slate-800\">{line.replace(\"### \", \"\")}</h3>;\n                  }\n                  if (line.startsWith(\"#### \")) {\n                    return <h4 key={idx} className=\"text-xs font-bold text-amber-400 mt-3\">{line.replace(\"#### \", \"\")}</h4>;\n                  }\n                  if (line.startsWith(\"- \")) {\n                    return <div key={idx} className=\"pl-3 py-0.5\">\342\200\242 {line.replace(\"- \", \"\")}</div>;\n                  }\n                  if (line.startsWith(\"1. \") || line.startsWith(\"2. \") || line.startsWith(\"3. \")) {\n                    return <div key={idx} className=\"pl-3 py-0.5 text-slate-300\">{line}</div>;\n                  }\n                  return <p key={idx} className=\"text-slate-300\">{line}</p>;\n                })}\n              </div>\n            </div>\n          )}\n\n        </div>\n\n      </div>\n    </div>\n  );"
      replacement_content: "  return (\n    <div className=\"flex-1 overflow-y-auto bg-natural-bg scrollbar-thin\" id=\"ai-copilot-workspace\">\n      {/* Page Header */}\n      <div className=\"px-6 py-4.5 bg-white border-b border-natural-border\">\n        <div className=\"text-xs font-bold text-natural-primary uppercase tracking-widest flex items-center gap-1\">\n          <Sparkles className=\"w-3.5 h-3.5 animate-pulse text-natural-primary\" /> Agile AI Copilot\n        </div>\n        <h1 className=\"text-2xl font-bold text-natural-text-deep tracking-tight mt-1\">\n          Scrum AI Assistant & Roadmapper\n        </h1>\n        <p className=\"text-xs text-natural-text-neutral mt-1\">\n          Plan entire sprints automatically or run an agile audit on your active Kanban board status to detect blockers.\n        </p>\n      </div>\n\n      <div className=\"p-6 max-w-5xl mx-auto w-full grid grid-cols-1 md:grid-cols-12 gap-6\">\n        \n        {/* LEFT COLUMN: Roadmap generator (7 columns) */}\n        <div className=\"md:col-span-7 space-y-6\">\n          \n          {/* Form */}\n          <div className=\"bg-white rounded-2xl border border-natural-border p-6 shadow-2xs\">\n            <h3 className=\"font-bold text-natural-text-deep mb-1 flex items-center gap-1.5 text-sm\">\n              <Sparkles className=\"w-4.5 h-4.5 text-natural-primary\" /> Sprint Goals AI Roadmapper\n            </h3>\n            <p className=\"text-xs text-natural-text-neutral mb-4 leading-relaxed\">\n              Type in a product requirement or milestone, and the copilot will automatically generate 4 to 7 structured Epics, Stories, and Bugs.\n            </p>\n\n            <form onSubmit={handleGenerateRoadmap} className=\"space-y-4\">\n              <div>\n                <textarea\n                  value={goalInput}\n                  onChange={(e) => setGoalInput(e.target.value)}\n                  placeholder=\"e.g. Integrate a Stripe checkout subscription system supporting monthly and annual billing with a graceful loading portal\"\n                  required\n                  rows={3}\n                  className=\"w-full px-3.5 py-2.5 text-xs border border-natural-border bg-white rounded-xl focus:ring-1 focus:ring-natural-primary focus:outline-hidden text-natural-text-deep placeholder:text-natural-text-light shadow-2xs\"\n                />\n              </div>\n\n              <div className=\"flex justify-end\">\n                <button\n                  type=\"submit\"\n                  disabled={loading}\n                  className=\"px-5 py-2.5 bg-natural-primary hover:bg-natural-primary-hover disabled:bg-natural-border disabled:text-natural-text-light text-white font-bold text-xs rounded-full transition-all shadow-xs cursor-pointer flex items-center gap-1.5\"\n                >\n                  <Sparkles className=\"w-3.5 h-3.5\" /> {loading ? \"Generating Roadmap...\" : \"Generate Proposed Backlog\"}\n                </button>\n              </div>\n            </form>\n          </div>\n\n          {/* Proposal loading status */}\n          {loading && (\n            <div className=\"bg-white rounded-2xl border border-natural-border p-8 text-center shadow-2xs animate-pulse\">\n              <RefreshCw className=\"w-8 h-8 text-natural-primary animate-spin mx-auto mb-3\" />\n              <h4 className=\"font-bold text-natural-text-deep text-sm\">Jira AI Agent Thinking...</h4>\n              <p className=\"text-xs text-natural-text-neutral mt-1.5\">{loadingStep}</p>\n            </div>\n          )}\n\n          {/* Proposal Review List */}\n          {proposedIssues.length > 0 && (\n            <div className=\"bg-white rounded-2xl border border-natural-border overflow-hidden shadow-xs animate-in fade-in duration-300\">\n              <div className=\"px-5 py-4 bg-natural-sidebar border-b border-natural-border text-natural-text-deep flex items-center justify-between\">\n                <div>\n                  <h4 className=\"font-bold text-xs uppercase tracking-widest text-natural-primary\">Review Proposed Roadmap</h4>\n                  <p className=\"text-[10px] text-natural-text-neutral mt-0.5\">Generated {proposedIssues.length} issues for your backlog</p>\n                </div>\n                <button\n                  onClick={handleBulkImport}\n                  className=\"px-4 py-2 bg-natural-primary hover:bg-natural-primary-hover text-white font-bold text-xs rounded-full shadow-xs transition-colors flex items-center gap-1 cursor-pointer\"\n                >\n                  Import All to Backlog <ArrowRight className=\"w-3.5 h-3.5\" />\n                </button>\n              </div>\n\n              <div className=\"divide-y divide-natural-border/60 max-h-[480px] overflow-y-auto scrollbar-thin\">\n                {proposedIssues.map((issue, index) => (\n                  <div key={index} className=\"p-4 bg-white hover:bg-natural-hover-bg transition-colors\">\n                    <div className=\"flex items-start justify-between gap-3 mb-1.5\">\n                      <div className=\"flex items-center gap-2\">\n                        <span>{getIssueTypeIcon(issue.issueType)}</span>\n                        <span className=\"text-[10px] font-bold text-natural-text-neutral uppercase tracking-widest\">{issue.issueType}</span>\n                        <h5 className=\"font-bold text-natural-text-deep text-xs\">{issue.summary}</h5>\n                      </div>\n                      <span className={`px-2.5 py-0.5 rounded-full border font-bold text-[9px] ${getPriorityBadgeColor(issue.priority)}`}>\n                        {issue.priority}\n                      </span>\n                    </div>\n\n                    <p className=\"text-xs text-natural-text-neutral leading-relaxed pl-6 italic mb-2\">\n                      {issue.description}\n                    </p>\n\n                    <div className=\"flex items-center gap-3 pl-6 text-[10px] text-natural-text-neutral font-medium\">\n                      <span>Estimated Points: <strong className=\"text-natural-primary font-bold\">{issue.storyPoints} SP</strong></span>\n                      <span>\342\200\242</span>\n                      <span>Initial Status: <strong className=\"text-natural-accent font-bold\">{issue.initialStatus}</strong></span>\n                    </div>\n                  </div>\n                ))}\n              </div>\n            </div>\n          )}\n\n        </div>\n\n        {/* RIGHT COLUMN: PM Health check & standup assistant (5 columns) */}\n        <div className=\"md:col-span-5 space-y-6\">\n          \n          <div className=\"bg-white rounded-2xl border border-natural-border p-6 shadow-2xs\">\n            <h3 className=\"font-bold text-natural-text-deep mb-1 flex items-center gap-1.5 text-sm\">\n              <Clipboard className=\"w-4.5 h-4.5 text-natural-primary\" /> Scrum Coach Audit\n            </h3>\n            <p className=\"text-xs text-natural-text-neutral mb-4 leading-relaxed\">\n              Initiate a live project health check. The Scrum Coach AI will analyze active story metrics, identify unassigned tickets, and highlight workload bottlenecks.\n            </p>\n\n            <button\n              onClick={handleHealthCheck}\n              disabled={checkingHealth}\n              className=\"w-full py-2.5 bg-natural-primary hover:bg-natural-primary-hover text-white font-bold text-xs rounded-full shadow-xs transition-colors cursor-pointer\"\n            >\n              {checkingHealth ? \"Running Heuristics Audit...\" : \"Run Scrum Health Check\"}\n            </button>\n          </div>\n\n          {/* Heuristic Audit Output */}\n          {healthFeedback && (\n            <div className=\"bg-natural-sidebar text-natural-text-deep rounded-2xl p-6 shadow-xs border border-natural-border animate-in slide-in-from-bottom-2 duration-300\">\n              <div className=\"prose prose-xs leading-relaxed space-y-3 font-medium text-xs text-natural-text-neutral\">\n                {/* Visual markdown formatter */}\n                {healthFeedback.split(\"\\n\").map((line, idx) => {\n                  if (line.startsWith(\"### \")) {\n                    return <h3 key={idx} className=\"text-sm font-bold text-natural-primary mt-4 first:mt-0 pb-1 border-b border-natural-border/60\">{line.replace(\"### \", \"\")}</h3>;\n                  }\n                  if (line.startsWith(\"#### \")) {\n                    return <h4 key={idx} className=\"text-xs font-bold text-natural-accent mt-3\">{line.replace(\"#### \", \"\")}</h4>;\n                  }\n                  if (line.startsWith(\"- \")) {\n                    return <div key={idx} className=\"pl-3 py-0.5\">\342\200\242 {line.replace(\"- \", \"\")}</div>;\n                  }\n                  if (line.startsWith(\"1. \") || line.startsWith(\"2. \") || line.startsWith(\"3. \")) {\n                    return <div key={idx} className=\"pl-3 py-0.5 text-natural-text-neutral\">{line}</div>;\n                  }\n                  return <p key={idx} className=\"text-natural-text-neutral\">{line}</p>;\n                })}\n              </div>\n            </div>\n          )}\n\n        </div>\n\n      </div>\n    </div>\n  );"
    }
    instruction: "Apply Natural Tones design theme to AICopilot layout, form, proposed issues review, and Scrum Coach output card"
  }
}
