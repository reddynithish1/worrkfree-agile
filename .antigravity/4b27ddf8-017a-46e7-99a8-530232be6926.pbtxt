id-cols-2 gap-4\">\n                {/* Type */}\n                <div>\n                  <label className=\"block text-xs font-semibold text-natural-text-neutral uppercase tracking-wider mb-1.5\">\n                    Issue Type\n                  </label>\n                  <select\n                    value={quickType}\n                    onChange={(e) => setQuickType(e.target.value as IssueType)}\n                    className=\"w-full px-3 py-2 text-sm border border-natural-border bg-white rounded-xl focus:ring-2 focus:ring-natural-primary/20 focus:outline-hidden\"\n                  >\n                    <option value=\"Story\">Story</option>\n                    <option value=\"Task\">Task</option>\n                    <option value=\"Bug\">Bug</option>\n                    <option value=\"Epic\">Epic</option>\n                  </select>\n                </div>\n\n                {/* Priority */}\n                <div>\n                  <label className=\"block text-xs font-semibold text-natural-text-neutral uppercase tracking-wider mb-1.5\">\n                    Priority\n                  </label>\n                  <select\n                    value={quickPriority}\n                    onChange={(e) => setQuickPriority(e.target.value as IssuePriority)}\n                    className=\"w-full px-3 py-2 text-sm border border-natural-border bg-white rounded-xl focus:ring-2 focus:ring-natural-primary/20 focus:outline-hidden\"\n                  >\n                    <option value=\"Highest\">Highest</option>\n                    <option value=\"High\">High</option>\n                    <option value=\"Medium\">Medium</option>\n                    <option value=\"Low\">Low</option>\n                  </select>\n                </div>\n              </div>\n\n              <div className=\"grid grid-cols-2 gap-4\">\n                {/* Assignee */}\n                <div>\n                  <label className=\"block text-xs font-semibold text-natural-text-neutral uppercase tracking-wider mb-1.5\">\n                    Assignee\n                  </label>\n                  <select\n                    value={quickAssignee.name}\n                    onChange={(e) => {\n                      const user = SEED_USERS.find(u => u.name === e.target.value);\n                      if (user) setQuickAssignee(user);\n                    }}\n                    className=\"w-full px-3 py-2 text-sm border border-natural-border bg-white rounded-xl focus:ring-2 focus:ring-natural-primary/20 focus:outline-hidden\"\n                  >\n                    {SEED_USERS.map((user) => (\n                      <option key={user.email} value={user.name}>\n                        {user.name}\n                      </option>\n                    ))}\n                  </select>\n                </div>\n\n                {/* Story Points */}\n                <div>\n                  <label className=\"block text-xs font-semibold text-natural-text-neutral uppercase tracking-wider mb-1.5\">\n                    Story Points\n                  </label>\n                  <select\n                    value={quickPoints}\n                    onChange={(e) => setQuickPoints(Number(e.target.value))}\n                    className=\"w-full px-3 py-2 text-sm border border-natural-border bg-white rounded-xl focus:ring-2 focus:ring-natural-primary/20 focus:outline-hidden\"\n                  >\n                    {[1, 2, 3, 5, 8, 13].map(sp => (\n                      <option key={sp} value={sp}>{sp}</option>\n                    ))}\n                  </select>\n                </div>\n              </div>\n\n              <div className=\"pt-4 flex items-center justify-end gap-3 border-t border-natural-border\">\n                <button\n                  type=\"button\"\n                  onClick={() => setIsQuickCreateOpen(false)}\n                  className=\"px-4 py-2 text-sm font-semibold text-natural-text-neutral hover:text-natural-text-deep t