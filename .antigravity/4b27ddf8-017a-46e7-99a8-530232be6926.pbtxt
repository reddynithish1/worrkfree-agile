        }
        lines {
          text: "    description: `### Issue"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Engine profiling shows a slow but steady heap size expansion during high concurrency pooling. It is traced back to open DB connections that are not closed on socket timeout exceptions."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "### Acceptance Criteria"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "- [ ] Hook error callbacks to release pool resources instantly."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "- [ ] Add Jest leak test cases validating garbage collection."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "- [ ] Memory remains stable beneath 150MB after 100K simulated requests.`,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
