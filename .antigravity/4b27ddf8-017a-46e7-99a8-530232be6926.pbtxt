    instruction: "Styling SprintContainer list rows, header metrics, and inline creators with Natural Tones colors and round shapes"
    replacement_infos {
      original_chunk {
        target_content: "  return (\n    <div className=\"bg-white rounded-lg border border-slate-200 overflow-hidden shadow-2xs\">\n      {/* Sprint Header Row */}\n      <div className=\"px-4 py-3 bg-slate-100 border-b border-slate-200 flex flex-wrap items-center justify-between gap-3 select-none\">\n        <div className=\"flex items-center gap-2 cursor-pointer\" onClick={() => !isBacklog && onToggleCollapse()}>\n          {!isBacklog && (\n            isCollapsed ? <ChevronRight className=\"w-4 h-4 text-slate-500\" /> : <ChevronDown className=\"w-4 h-4 text-slate-500\" />\n          )}\n          <span className=\"font-bold text-slate-800 text-sm\">\n            {isBacklog ? \"Product Backlog\" : sprint.name}\n          </span>\n          <span className=\"text-[11px] font-semibold text-slate-500\">\n            ({metrics.count} issues)\n          </span>\n\n          {sprint?.status === \"active\" && (\n            <span className=\"text-[10px] font-bold px-2 py-0.5 bg-emerald-100 text-emerald-800 rounded border border-emerald-200\">\n              Active Sprint\n            </span>\n          )}\n        </div>\n\n        {/* Stats segment */}\n        <div className=\"flex items-center gap-3\">\n          <div className=\"flex items-center gap-1.5 text-xs\">\n            <span className=\"w-2.5 h-2.5 rounded-full bg-slate-300\" title=\"To Do\" />\n            <span className=\"font-bold text-slate-600\">{metrics.todoPoints}</span>\n            <span className=\"w-2.5 h-2.5 rounded-full bg-blue-500\" title=\"In Progress & Review\" />\n            <span className=\"font-bold text-slate-600\">{metrics.progressPoints}</span>\n            <span className=\"w-2.5 h-2.5 rounded-full bg-emerald-500\" title=\"Done\" />\n            <span className=\"font-bold text-emerald-600\">{metrics.donePoints}</span>\n            <span className=\"text-slate-400 font-normal ml-1\">SP total</span>\n          </div>\n\n          <div className=\"h-4 w-[1px] bg-slate-300 hidden sm:block\" />\n\n          {/* Header Actions */}\n          {!isBacklog && (\n            <div className=\"flex items-center gap-2\">\n              {sprint.status === \"active\" && onCompleteSprint && (\n                <button\n                  onClick={(e) => { e.stopPropagation(); onCompleteSprint(); }}\n                  className=\"flex items-center gap-1 px-2.5 py-1 bg-emerald-600 hover:bg-emerald-700 text-white text-[11px] font-bold rounded-md transition-colors\"\n                >\n                  <CheckCircle2 className=\"w-3.5 h-3.5\" /> Complete Sprint\n                </button>\n              )}\n              {sprint.status === \"future\" && onStartSprint && (\n                <button\n                  disabled={disableStart}\n                  onClick={(e) => { e.stopPropagation(); onStartSprint(); }}\n                  className={`flex items-center gap-1 px-2.5 py-1 text-white text-[11px] font-bold rounded-md transition-colors ${\n                    disableStart \n                      ? \"bg-slate-400 cursor-not-allowed\" \n                      : \"bg-blue-600 hover:bg-blue-700\"\n                  }`}\n                  title={disableStart ? \"You can only run one active sprint at a time\" : \"Start this sprint now\"}\n                >\n                  <Play className=\"w-3.5 h-3.5\" /> Start Sprint\n                </button>\n              )}\n            </div>\n          )}\n        </div>\n      </div>\n\n      {/* Issues Sub-List */}\n      {!isCollapsed && (\n        <div className=\"divide-y divide-slate-100\">\n          {issues.length === 0 ? (\n            <div className=\"px-4 py-8 text-center text-xs text-slate-400 bg-white\">\n              No issues in this sprint. Click \"Create backlog item\" below to plan scope.\n            </div>\n          ) : (\n            issues.map((issue) => (\n              <div\n                key={issue.id}\n                onClick={() => onOpenIssueDetail(issue)}\n                className=\"px-4 py-2.5 bg-white hover:bg-slate-50 transition-colors flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2.5 cursor-pointer text-xs\"\n              >\n                {/* Left cell: Type, Key, Summary */}\n                <div className=\"flex items-center gap-2.5 min-w-0 flex-1\">\n                  <span className=\"shrink-0\">{getIssueTypeIcon(issue.type)}</span>\n                  <span className=\"font-bold text-slate-500 tracking-tight shrink-0 select-all\">\n                    {issue.key}\n                  </span>\n                  <span className=\"text-slate-800 font-medium truncate\">\n                    {issue.summary}\n                  </span>\n                </div>\n\n                {/* Right cell: Assignee, Priority, SP, Status, Destination Sprint */}\n                <div className=\"flex items-center gap-3 shrink-0 self-end sm:self-center\">\n                  {/* Status pill */}\n                  <span className={`px-2 py-0.5 font-bold rounded-sm border text-[10px] uppercase tracking-wide ${getStatusBadgeClass(issue.status)}`}>\n                    {issue.status}\n                  </span>\n\n                  {/* Priority icon */}\n                  <span>{getPriorityIcon(issue.priority)}</span>\n\n                  {/* Story point badge */}\n                  <span className=\"w-5 h-5 rounded-full bg-slate-100 border border-slate-200 text-slate-600 flex items-center justify-center font-bold text-[10px]\">\n                    {issue.storyPoints || \"-\"}\n                  </span>\n\n                  {/* Assignee Avatar */}\n                  <img\n                    src={issue.assignee.avatar}\n                    alt={issue.assignee.name}\n                    className=\"w-5.5 h-5.5 rounded-full ring-1 ring-slate-200 object-cover\"\n                    title={`Assigned to ${issue.assignee.name}`}\n                    referrerPolicy=\"no-referrer\"\n                  />\n\n                  {/* Move Sprint destination selector */}\n                  <div className=\"relative\" onClick={(e) => e.stopPropagation()}>\n                    <select\n                      value={sprintId || \"backlog\"}\n                      onChange={(e) => {\n                        const target = e.target.value === \"backlog\" ? null : e.target.value;\n                        onMoveIssue(issue.id, target);\n                      }}\n                      className=\"px-2 py-0.5 text-[10px] font-medium bg-slate-100 border border-slate-200 rounded text-slate-600 cursor-pointer\"\n                    >\n                      <option value=\"backlog\">Backlog</option>\n                      {allSprints\n                        .filter((s) => s.status !== \"completed\")\n                        .map((s) => (\n                          <option key={s.id} value={s.id}>\n                            {s.name.length > 20 ? `${s.name.substring(0, 20)}...` : s.name}\n                          </option>\n                        ))}\n                    </select>\n                  </div>\n                </div>\n              </div>\n            ))\n          )}\n\n          {/* Quick Issue Creator row inside this list container */}\n          <div className=\"px-4 py-2 bg-slate-50\">\n            {activeCreatorSprintId === sprintId ? (\n              <div className=\"flex items-center gap-2 animate-in slide-in-from-top-1 duration-150\">\n                <select\n                  value={newIssueType}\n                  onChange={(e) => setNewIssueType(e.target.value as IssueType)}\n                  className=\"px-2 py-1.5 text-xs bg-white border border-slate-200 rounded-md text-slate-700\"\n                >\n                  <option value=\"Story\">Story</option>\n                  <option value=\"Task\">Task</option>\n                  <option value=\"Bug\">Bug</option>\n                  <option value=\"Epic\">Epic</option>\n                </select>\n                <input\n                  type=\"text\"\n                  placeholder=\"What needs to be done? Press Enter or Click \'+\'\"\n                  value={newIssueSummary}\n                  onChange={(e) => setNewIssueSummary(e.target.value)}\n                  onKeyDown={(e) => {\n                    if (e.key === \"Enter\") {\n                      onAddIssue(sprintId);\n                    }\n                  }}\n                  className=\"flex-1 px-3 py-1.5 text-xs border border-slate-200 rounded bg-white\"\n                  autoFocus\n                />\n                <button\n                  onClick={() => onAddIssue(sprintId)}\n                  className=\"px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded text-xs\"\n                >\n                  Add\n                </button>\n                <button\n                  onClick={() => setActiveCreatorSprintId(undefined)}\n                  className=\"px-2.5 py-1.5 text-xs text-slate-500 hover:text-slate-800\"\n                >\n                  Cancel\n                </button>\n              </div>\n            ) : (\n              <button\n                onClick={() => {\n                  setNewIssueSummary(\"\");\n                  setActiveCreatorSprintId(sprintId);\n                }}\n                className=\"flex items-center gap-1.5 text-blue-600 hover:text-blue-800 font-semibold text-xs py-1\"\n              >\n                <Plus className=\"w-3.5 h-3.5\" /> Create {isBacklog ? \"backlog item\" : \"issue in this sprint\"}\n              </button>\n            )}\n          </div>\n        </div>\n      )}\n    </div>\n  );"
        replacement_content: "  return (\n    <div className=\"bg-white rounded-2xl border border-natural-border overflow-hidden shadow-2xs\">\n      {/* Sprint Header Row */}\n      <div className=\"px-4 py-3 bg-natural-sidebar border-b border-natural-border flex flex-wrap items-center justify-between gap-3 select-none\">\n        <div className=\"flex items-center gap-2 cursor-pointer\" onClick={() => !isBacklog && onToggleCollapse()}>\n          {!isBacklog && (\n            isCollapsed ? <ChevronRight className=\"w-4 h-4 text-natural-text-neutral\" /> : <ChevronDown className=\"w-4 h-4 text-natural-text-neutral\" />\n          )}\n          <span className=\"font-bold text-natural-text-deep text-sm\">\n            {isBacklog ? \"Product Backlog\" : sprint.name}\n          </span>\n          <span className=\"text-[11px] font-semibold text-natural-text-light\">\n            ({metrics.count} issues)\n          </span>\n\n          {sprint?.status === \"active\" && (\n            <span className=\"text-[9px] font-bold px-2 py-0.5 bg-natural-primary/10 text-natural-primary rounded-full border border-natural-primary/20\">\n              Active Sprint\n            </span>\n          )}\n        </div>\n\n        {/* Stats segment */}\n        <div className=\"flex items-center gap-3\">\n          <div className=\"flex items-center gap-1.5 text-xs\">\n            <span className=\"w-2.5 h-2.5 rounded-full bg-natural-border\" title=\"To Do\" />\n            <span className=\"font-bold text-natural-text-deep\">{metrics.todoPoints}</span>\n            <span className=\"w-2.5 h-2.5 rounded-full bg-natural-accent\" title=\"In Progress & Review\" />\n            <span className=\"font-bold text-natural-text-deep\">{metrics.progressPoints}</span>\n            <span className=\"w-2.5 h-2.5 rounded-full bg-natural-primary\" title=\"Done\" />\n            <span className=\"font-bold text-natural-primary\">{metrics.donePoints}</span>\n            <span className=\"text-natural-text-light font-normal ml-1\">SP total</span>\n          </div>\n\n          <div className=\"h-4 w-[1px] bg-natural-border hidden sm:block\" />\n\n          {/* Header Actions */}\n          {!isBacklog && (\n            <div className=\"flex items-center gap-2\">\n              {sprint.status === \"active\" && onCompleteSprint && (\n                <button\n                  onClick={(e) => { e.stopPropagation(); onCompleteSprint(); }}\n                  className=\"flex items-center gap-1 px-3 py-1 bg-natural-primary hover:bg-natural-primary-hover text-white text-[11px] font-bold rounded-full transition-colors shadow-2xs\"\n                >\n                  <CheckCircle2 className=\"w-3.5 h-3.5\" /> Complete Sprint\n                </button>\n              )}\n              {sprint.status === \"future\" && onStartSprint && (\n                <button\n                  disabled={disableStart}\n                  onClick={(e) => { e.stopPropagation(); onStartSprint(); }}\n                  className={`flex items-center gap-1 px-3 py-1 text-white text-[11px] font-bold rounded-full transition-colors shadow-2xs ${\n                    disableStart \n                      ? \"bg-natural-border text-natural-text-light cursor-not-allowed\" \n                      : \"bg-natural-primary hover:bg-natural-primary-hover\"\n                  }`}\n                  title={disableStart ? \"You can only run one active sprint at a time\" : \"Start this sprint now\"}\n                >\n                  <Play className=\"w-3.5 h-3.5\" /> Start Sprint\n                </button>\n              )}\n            </div>\n          )}\n        </div>\n      </div>\n\n      {/* Issues Sub-List */}\n      {!isCollapsed && (\n        <div className=\"divide-y divide-natural-border/40\">\n          {issues.length === 0 ? (\n            <div className=\"px-4 py-8 text-center text-xs text-natural-text-neutral bg-white\">\n              No issues in this sprint. Click \"Create backlog item\" below to plan scope.\n            </div>\n          ) : (\n            issues.map((issue) => (\n              <div\n                key={issue.id}\n                onClick={() => onOpenIssueDetail(issue)}\n                className=\"px-4 py-2.5 bg-white hover:bg-natural-hover-bg transition-colors flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2.5 cursor-pointer text-xs\"\n              >\n                {/* Left cell: Type, Key, Summary */}\n                <div className=\"flex items-center gap-2.5 min-w-0 flex-1\">\n                  <span className=\"shrink-0\">{getIssueTypeIcon(issue.type)}</span>\n                  <span className=\"font-bold text-natural-text-light tracking-tight shrink-0 select-all\">\n                    {issue.key}\n                  </span>\n                  <span className=\"text-natural-text-deep font-semibold truncate\">\n                    {issue.summary}\n                  </span>\n                </div>\n\n                {/* Right cell: Assignee, Priority, SP, Status, Destination Sprint */}\n                <div className=\"flex items-center gap-3 shrink-0 self-end sm:self-center\">\n                  {/* Status pill */}\n                  <span className={`px-2 py-0.5 font-bold rounded-full border text-[10px] uppercase tracking-wide ${getStatusBadgeClass(issue.status)}`}>\n                    {issue.status}\n                  </span>\n\n                  {/* Priority icon */}\n                  <span>{getPriorityIcon(issue.priority)}</span>\n\n                  {/* Story point badge */}\n                  <span className=\"w-5 h-5 rounded-full bg-natural-sidebar border border-natural-border text-natural-text-neutral flex items-center justify-center font-bold text-[10px]\">\n                    {issue.storyPoints || \"-\"}\n                  </span>\n\n                  {/* Assignee Avatar */}\n                  <img\n                    src={issue.assignee.avatar}\n                    alt={issue.assignee.name}\n                    className=\"w-5.5 h-5.5 rounded-full ring-1 ring-natural-border object-cover\"\n                    title={`Assigned to ${issue.assignee.name}`}\n                    referrerPolicy=\"no-referrer\"\n                  />\n\n                  {/* Move Sprint destination selector */}\n                  <div className=\"relative\" onClick={(e) => e.stopPropagation()}>\n                    <select\n                      value={sprintId || \"backlog\"}\n                      onChange={(e) => {\n                        const target = e.target.value === \"backlog\" ? null : e.target.value;\n                        onMoveIssue(issue.id, target);\n                      }}\n                      className=\"px-2 py-0.5 text-[10px] font-bold bg-white border border-natural-border rounded-lg text-natural-text-neutral cursor-pointer hover:border-natural-primary transition-all focus:outline-hidden\"\n                    >\n                      <option value=\"backlog\">Backlog</option>\n                      {allSprints\n                        .filter((s) => s.status !== \"completed\")\n                        .map((s) => (\n                          <option key={s.id} value={s.id}>\n                            {s.name.length > 20 ? `${s.name.substring(0, 20)}...` : s.name}\n                          </option>\n                        ))}\n                    </select>\n                  </div>\n                </div>\n              </div>\n            ))\n          )}\n\n          {/* Quick Issue Creator row inside this list container */}\n          <div className=\"px-4 py-2 bg-natural-sidebar/50 border-t border-natural-border\">\n            {activeCreatorSprintId === sprintId ? (\n              <div className=\"flex items-center gap-2 animate-in slide-in-from-top-1 duration-150\">\n                <select\n                  value={newIssueType}\n                  onChange={(e) => setNewIssueType(e.target.value as IssueType)}\n                  className=\"px-2.5 py-1.5 text-xs bg-white border border-natural-border rounded-xl text-natural-text-deep focus:ring-1 focus:ring-natural-primary focus:outline-hidden\"\n                >\n                  <option value=\"Story\">Story</option>\n                  <option value=\"Task\">Task</option>\n                  <option value=\"Bug\">Bug</option>\n                  <option value=\"Epic\">Epic</option>\n                </select>\n                <input\n                  type=\"text\"\n                  placeholder=\"What needs to be done? Press Enter or Click \'+\'\"\n                  value={newIssueSummary}\n                  onChange={(e) => setNewIssueSummary(e.target.value)}\n                  onKeyDown={(e) => {\n                    if (e.key === \"Enter\") {\n                      onAddIssue(sprintId);\n                    }\n                  }}\n                  className=\"flex-1 px-3 py-1.5 text-xs border border-natural-border rounded-xl bg-white text-natural-text-deep placeholder:text-natural-text-light focus:ring-1 focus:ring-natural-primary focus:outline-hidden\"\n                  autoFocus\n                />\n                <button\n                  onClick={() => onAddIssue(sprintId)}\n                  className=\"px-4 py-1.5 bg-natural-primary hover:bg-natural-primary-hover text-white font-bold rounded-full text-xs shadow-2xs transition-all\"\n                >\n                  Add\n                </button>\n                <button\n                  onClick={() => setActiveCreatorSprintId(undefined)}\n                  className=\"px-3 py-1.5 text-xs font-semibold text-natural-text-neutral hover:text-natural-text-deep transition-colors\"\n                >\n                  Cancel\n                </button>\n              </div>\n            ) : (\n              <button\n                onClick={() => {\n                  setNewIssueSummary(\"\");\n                  setActiveCreatorSprintId(sprintId);\n                }}\n                className=\"flex items-center gap-1.5 text-natural-primary hover:text-natural-primary-hover font-bold text-xs py-1 transition-colors\"\n              >\n                <Plus className=\"w-3.5 h-3.5\" /> Create {isBacklog ? \"backlog item\" : \"issue in this sprint\"}\n              </button>\n            )}\n          </div>\n        </div>\n      )}\n    </div>\n  );"
