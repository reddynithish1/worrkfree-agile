        }
        lines {
          text: "  const velocityData = projectSprints.map((sprint) => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const sprintIssues = projectIssues.filter((i) => i.sprintId === sprint.id);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const sprintDonePoints = sprintIssues"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      .filter((i) => i.status === \"Done\")"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      .reduce((sum, i) => sum + (i.storyPoints || 0), 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const sprintTotalPoints = sprintIssues"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      .reduce((sum, i) => sum + (i.storyPoints || 0), 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      name: sprint.name.length > 15 ? `${sprint.name.substring(0, 15)}...` : sprint.name,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      donePoints: sprintDonePoints,"
