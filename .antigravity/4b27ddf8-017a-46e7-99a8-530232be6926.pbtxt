px-3.5 py-2 text-sm border border-natural-border bg-white rounded-xl focus:outline-hidden focus:ring-2 focus:ring-natural-primary/20 focus:border-natural-primary\"\n                 />\n               </div>\n\n               <div className=\"pt-4 flex items-center justify-end gap-3 border-t border-natural-border\">\n                 <button\n                   type=\"button\"\n                   onClick={() => setIsNewProjectOpen(false)}\n                   className=\"px-4 py-2 text-sm font-semibold text-natural-text-neutral hover:text-natural-text-deep transition-colors\"\n                 >\n                   Cancel\n                 </button>\n                 <button\n                   type=\"submit\"\n                   className=\"px-5 py-2 text-sm font-semibold bg-natural-primary hover:bg-natural-primary-hover text-white rounded-full shadow-xs transition-colors\"\n                 >\n                   Create Project\n                 </button>\n               </div>\n             </form>\n           </div>\n         </div>\n       )}"
