    file_change_type: FILE_CHANGE_TYPE_EDIT
    replacement_chunks {
      target_content: "        {/* RIGHT PANEL - Attributes sidebar (4 columns) */}\n        <div className=\"lg:col-span-4 bg-slate-50 border border-slate-100 rounded-xl p-4.5 space-y-5 h-fit\">\n          \n          {/* Status dropdown */}\n          <div>\n            <label className=\"block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1.5\">\n              Status\n            </label>\n            <select\n              value={issue.status}\n              onChange={(e) => updateAttribute(\"status\", e.target.value as IssueStatus)}\n              className=\"w-full px-3 py-1.5 text-xs bg-white border border-slate-200 rounded font-semibold text-slate-700 focus:ring-1\"\n            >\n              <option value=\"Backlog\">Backlog</option>\n              <option value=\"To Do\">To Do</option>\n              <option value=\"In Progress\">In Progress</option>\n              <option value=\"In Review\">In Review</option>\n              <option value=\"Done\">Done</option>\n            </select>\n          </div>\n\n          {/* Issue Type */}\n          <div>\n            <label className=\"block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1.5\">\n              Issue Type\n            </label>\n            <select\n              value={issue.type}\n              onChange={(e) => updateAttribute(\"type\", e.target.value as IssueType)}\n              className=\"w-full px-3 py-1.5 text-xs bg-white border border-slate-200 rounded font-semibold text-slate-700 focus:ring-1\"\n            >\n              <option value=\"Epic\">Epic</option>\n              <option value=\"Story\">Story</option>\n              <option value=\"Task\">Task</option>\n              <option value=\"Bug\">Bug</option>\n            </select>\n          </div>\n\n          {/* Assignee */}\n          <div>\n            <label className=\"block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1.5\">\n              Assignee\n            </label>\n            <select\n              value={issue.assignee.name}\n              onChange={(e) => {\n                const user = SEED_USERS.find(u => u.name === e.target.value);\n                if (user) updateAttribute(\"assignee\", user);\n              }}\n              className=\"w-full px-3 py-1.5 text-xs bg-white border border-slate-200 rounded text-slate-700 focus:ring-1\"\n            >\n              {SEED_USERS.map((user) => (\n                <option key={user.email} value={user.name}>\n                  {user.name}\n                </option>\n              ))}\n            </select>\n          </div>\n\n          {/* Priority */}\n          <div>\n            <label className=\"block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1.5\">\n              Priority\n            </label>\n            <select\n              value={issue.priority}\n              onChange={(e) => updateAttribute(\"priority\", e.target.value as IssuePriority)}\n              className=\"w-full px-3 py-1.5 text-xs bg-white border border-slate-200 rounded font-semibold text-slate-700 focus:ring-1\"\n            >\n              <option value=\"Highest\">Highest</option>\n              <option value=\"High\">High</option>\n              <option value=\"Medium\">Medium</option>\n              <option value=\"Low\">Low</option>\n            </select>\n          </div>\n\n          {/* Story Points */}\n          <div>\n            <label className=\"block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1.5\">\n              Story Points\n            </label>\n            <select\n              value={issue.storyPoints || 0}\n              onChange={(e) => updateAttribute(\"storyPoints\", Number(e.target.value))}\n              className=\"w-full px-3 py-1.5 text-xs bg-white border border-slate-200 rounded font-bold text-slate-700 focus:ring-1\"\n            >\n              <option value=\"0\">0 SP</option>\n              <option value=\"1\">1 SP</option>\n              <option value=\"2\">2 SP</option>\n              <option value=\"3\">3 SP</option>\n              <option value=\"5\">5 SP</option>\n              <option value=\"8\">8 SP</option>\n              <option value=\"13\">13 SP</option>\n            </select>\n          </div>\n\n          {/* Sprint association */}\n          <div>\n            <label className=\"block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1.5\">\n              Sprint\n            </label>\n            <select\n              value={issue.sprintId || \"backlog\"}\n              onChange={(e) => {\n                const val = e.target.value === \"backlog\" ? null : e.target.value;\n                updateAttribute(\"sprintId\", val);\n              }}\n              className=\"w-full px-3 py-1.5 text-xs bg-white border border-slate-200 rounded text-slate-700 focus:ring-1\"\n            >\n              <option value=\"backlog\">Product Backlog</option>\n              {sprints\n                .filter((s) => s.projectId === issue.projectId)\n                .map((s) => (\n                  <option key={s.id} value={s.id}>\n                    {s.name}\n                  </option>\n                ))}\n            </select>\n          </div>\n\n          {/* Work Log & Progress */}\n          <div className=\"border-t border-slate-200 pt-4\">\n            <div className=\"flex items-center justify-between mb-2\">\n              <label className=\"block text-[10px] font-bold text-slate-500 uppercase tracking-wider\">\n                Logged Work Time\n              </label>\n              <span className=\"text-xs font-bold text-slate-700\">{totalHoursSpent} hours</span>\n            </div>\n\n            {/* inline logging trigger */}\n            {!isLoggingWork ? (\n              <button\n                onClick={() => setIsLoggingWork(true)}\n                className=\"flex items-center gap-1.5 text-xs text-blue-600 hover:text-blue-800 font-semibold\"\n              >\n                <Clock className=\"w-3.5 h-3.5\" /> Log hours...\n              </button>\n            ) : (\n              <form onSubmit={handleLogWorkSubmit} className=\"space-y-2 p-2.5 bg-white border border-slate-200 rounded shadow-2xs\">\n                <div>\n                  <input\n                    type=\"number\"\n                    step=\"0.5\"\n                    min=\"0.5\"\n                    required\n                    placeholder=\"Log hours (e.g., 2.5)\"\n                    value={logHours}\n                    onChange={(e) => setLogHours(e.target.value)}\n                    className=\"w-full px-2 py-1 text-xs border border-slate-200 rounded\"\n                  />\n                </div>\n                <div>\n                  <input\n                    type=\"text\"\n                    placeholder=\"Brief description...\"\n                    value={logDesc}\n                    onChange={(e) => setLogDesc(e.target.value)}\n                    className=\"w-full px-2 py-1 text-xs border border-slate-200 rounded\"\n                  />\n                </div>\n                <div className=\"flex gap-2 justify-end\">\n                  <button\n                    type=\"button\"\n                    onClick={() => setIsLoggingWork(false)}\n                    className=\"text-[10px] font-bold text-slate-500 hover:text-slate-700\"\n                  >\n                    Cancel\n                  </button>\n                  <button\n                    type=\"submit\"\n                    className=\"px-2 py-1 bg-slate-900 hover:bg-slate-800 text-white font-bold text-[10px] rounded\"\n                  >\n                    Log Work\n                  </button>\n                </div>\n              </form>\n            )}\n\n            {/* History of work logs */}\n            {issue.workLogs.length > 0 && (\n              <div className=\"mt-3.5 max-h-[140px] overflow-y-auto space-y-2 divide-y divide-slate-100 scrollbar-thin\">\n                {issue.workLogs.map((wl) => (\n                  <div key={wl.id} className=\"text-[10px] text-slate-500 pt-2 first:pt-0\">\n                    <div className=\"flex items-center justify-between font-semibold\">\n                      <span>{wl.author}</span>\n                      <span className=\"text-slate-800 bg-slate-200 px-1 py-0.2 rounded font-bold\">{wl.hoursLogged}h</span>\n                    </div>\n                    <p className=\"italic text-slate-600 truncate mt-0.5\">\"{wl.description}\"</p>\n                  </div>\n                ))}\n              </div>\n            )}\n          </div>\n\n          {/* Time Dates stamp */}\n          <div className=\"border-t border-slate-200 pt-4 text-[10px] text-slate-400 space-y-1\">\n            <div>Created: {new Date(issue.createdAt).toLocaleString()}</div>\n            <div>Updated: {new Date(issue.updatedAt).toLocaleString()}</div>\n          </div>\n\n        </div>"
      replacement_content: "        {/* RIGHT PANEL - Attributes sidebar (4 columns) */}\n        <div className=\"lg:col-span-4 bg-natural-sidebar border border-natural-border rounded-2xl p-5 space-y-5 h-fit\">\n          \n          {/* Status dropdown */}\n          <div>\n            <label className=\"block text-[10px] font-bold text-natural-text-neutral uppercase tracking-wider mb-1.5\">\n              Status\n            </label>\n            <select\n              value={issue.status}\n              onChange={(e) => updateAttribute(\"status\", e.target.value as IssueStatus)}\n              className=\"w-full px-3 py-2 text-xs bg-white border border-natural-border rounded-xl font-semibold text-natural-text-deep focus:ring-1 focus:ring-natural-primary focus:outline-hidden shadow-2xs\"\n            >\n              <option value=\"Backlog\">Backlog</option>\n              <option value=\"To Do\">To Do</option>\n              <option value=\"In Progress\">In Progress</option>\n              <option value=\"In Review\">In Review</option>\n              <option value=\"Done\">Done</option>\n            </select>\n          </div>\n\n          {/* Issue Type */}\n          <div>\n            <label className=\"block text-[10px] font-bold text-natural-text-neutral uppercase tracking-wider mb-1.5\">\n              Issue Type\n            </label>\n            <select\n              value={issue.type}\n              onChange={(e) => updateAttribute(\"type\", e.target.value as IssueType)}\n              className=\"w-full px-3 py-2 text-xs bg-white border border-natural-border rounded-xl font-semibold text-natural-text-deep focus:ring-1 focus:ring-natural-primary focus:outline-hidden shadow-2xs\"\n            >\n              <option value=\"Epic\">Epic</option>\n              <option value=\"Story\">Story</option>\n              <option value=\"Task\">Task</option>\n              <option value=\"Bug\">Bug</option>\n            </select>\n          </div>\n\n          {/* Assignee */}\n          <div>\n            <label className=\"block text-[10px] font-bold text-natural-text-neutral uppercase tracking-wider mb-1.5\">\n              Assignee\n            </label>\n            <select\n              value={issue.assignee.name}\n              onChange={(e) => {\n                const user = SEED_USERS.find(u => u.name === e.target.value);\n                if (user) updateAttribute(\"assignee\", user);\n              }}\n              className=\"w-full px-3 py-2 text-xs bg-white border border-natural-border rounded-xl font-semibold text-natural-text-deep focus:ring-1 focus:ring-natural-primary focus:outline-hidden shadow-2xs\"\n            >\n              {SEED_USERS.map((user) => (\n                <option key={user.email} value={user.name}>\n                  {user.name}\n                </option>\n              ))}\n            </select>\n          </div>\n\n          {/* Priority */}\n          <div>\n            <label className=\"block text-[10px] font-bold text-natural-text-neutral uppercase tracking-wider mb-1.5\">\n              Priority\n            </label>\n            <select\n              value={issue.priority}\n              onChange={(e) => updateAttribute(\"priority\", e.target.value as IssuePriority)}\n              className=\"w-full px-3 py-2 text-xs bg-white border border-natural-border rounded-xl font-semibold text-natural-text-deep focus:ring-1 focus:ring-natural-primary focus:outline-hidden shadow-2xs\"\n            >\n              <option value=\"Highest\">Highest</option>\n              <option value=\"High\">High</option>\n              <option value=\"Medium\">Medium</option>\n              <option value=\"Low\">Low</option>\n            </select>\n          </div>\n\n          {/* Story Points */}\n          <div>\n            <label className=\"block text-[10px] font-bold text-natural-text-neutral uppercase tracking-wider mb-1.5\">\n              Story Points\n            </label>\n            <select\n              value={issue.storyPoints || 0}\n              onChange={(e) => updateAttribute(\"storyPoints\", Number(e.target.value))}\n              className=\"w-full px-3 py-2 text-xs bg-white border border-natural-border rounded-xl font-bold text-natural-text-deep focus:ring-1 focus:ring-natural-primary focus:outline-hidden shadow-2xs\"\n            >\n              <option value=\"0\">0 SP</option>\n              <option value=\"1\">1 SP</option>\n              <option value=\"2\">2 SP</option>\n              <option value=\"3\">3 SP</option>\n              <option value=\"5\">5 SP</option>\n              <option value=\"8\">8 SP</option>\n              <option value=\"13\">13 SP</option>\n            </select>\n          </div>\n\n          {/* Sprint association */}\n          <div>\n            <label className=\"block text-[10px] font-bold text-natural-text-neutral uppercase tracking-wider mb-1.5\">\n              Sprint\n            </label>\n            <select\n              value={issue.sprintId || \"backlog\"}\n              onChange={(e) => {\n                const val = e.target.value === \"backlog\" ? null : e.target.value;\n                updateAttribute(\"sprintId\", val);\n              }}\n              className=\"w-full px-3 py-2 text-xs bg-white border border-natural-border rounded-xl text-natural-text-deep focus:ring-1 focus:ring-natural-primary focus:outline-hidden shadow-2xs\"\n            >\n              <option value=\"backlog\">Product Backlog</option>\n              {sprints\n                .filter((s) => s.projectId === issue.projectId)\n                .map((s) => (\n                  <option key={s.id} value={s.id}>\n                    {s.name}\n                  </option>\n                ))}\n            </select>\n          </div>\n\n          {/* Work Log & Progress */}\n          <div className=\"border-t border-natural-border pt-4\">\n            <div className=\"flex items-center justify-between mb-2\">\n              <label className=\"block text-[10px] font-bold text-natural-text-neutral uppercase tracking-wider\">\n                Logged Work Time\n              </label>\n              <span className=\"text-xs font-bold text-natural-text-deep bg-natural-primary/10 text-natural-primary rounded-full px-2 py-0.5 border border-natural-primary/20\">{totalHoursSpent} hours</span>\n            </div>\n\n            {/* inline logging trigger */}\n            {!isLoggingWork ? (\n              <button\n                onClick={() => setIsLoggingWork(true)}\n                className=\"flex items-center gap-1.5 text-xs text-natural-primary hover:text-natural-primary-hover font-bold transition-colors\"\n              >\n                <Clock className=\"w-3.5 h-3.5\" /> Log hours...\n              </button>\n            ) : (\n              <form onSubmit={handleLogWorkSubmit} className=\"space-y-2.5 p-3.5 bg-white border border-natural-border rounded-2xl shadow-2xs\">\n                <div>\n                  <input\n                    type=\"number\"\n                    step=\"0.5\"\n                    min=\"0.5\"\n                    required\n                    placeholder=\"Log hours (e.g., 2.5)\"\n                    value={logHours}\n                    onChange={(e) => setLogHours(e.target.value)}\n                    className=\"w-full px-3 py-1.5 text-xs bg-white border border-natural-border rounded-xl text-natural-text-deep focus:ring-1 focus:ring-natural-primary focus:outline-hidden\"\n                  />\n                </div>\n                <div>\n                  <input\n                    type=\"text\"\n                    placeholder=\"Brief description...\"\n                    value={logDesc}\n                    onChange={(e) => setLogDesc(e.target.value)}\n                    className=\"w-full px-3 py-1.5 text-xs bg-white border border-natural-border rounded-xl text-natural-text-deep focus:ring-1 focus:ring-natural-primary focus:outline-hidden\"\n                  />\n                </div>\n                <div className=\"flex gap-2 justify-end items-center\">\n                  <button\n                    type=\"button\"\n                    onClick={() => setIsLoggingWork(false)}\n                    className=\"text-[10px] font-bold text-natural-text-neutral hover:text-natural-text-deep transition-colors\"\n                  >\n                    Cancel\n                  </button>\n                  <button\n                    type=\"submit\"\n                    className=\"px-3.5 py-1.5 bg-natural-primary hover:bg-natural-primary-hover text-white font-bold text-[10px] rounded-full shadow-xs transition-colors\"\n                  >\n                    Log Work\n                  </button>\n                </div>\n              </form>\n            )}\n\n            {/* History of work logs */}\n            {issue.workLogs.length > 0 && (\n              <div className=\"mt-3.5 max-h-[140px] overflow-y-auto space-y-2 divide-y divide-natural-border/40 scrollbar-thin\">\n                {issue.workLogs.map((wl) => (\n                  <div key={wl.id} className=\"text-[10px] text-natural-text-neutral pt-2.5 first:pt-0\">\n                    <div className=\"flex items-center justify-between font-semibold mb-1\">\n                      <span className=\"text-natural-text-deep\">{wl.author}</span>\n                      <span className=\"text-natural-primary bg-natural-primary/10 border border-natural-primary/20 px-2 py-0.5 rounded-full font-bold\">{wl.hoursLogged}h</span>\n                    </div>\n                    <p className=\"italic text-natural-text-neutral truncate mt-0.5\">\"{wl.description}\"</p>\n                  </div>\n                ))}\n              </div>\n            )}\n          </div>\n\n          {/* Time Dates stamp */}\n          <div className=\"border-t border-natural-border pt-4 text-[9px] text-natural-text-light font-medium space-y-1\">\n            <div>Created: {new Date(issue.createdAt).toLocaleString()}</div>\n            <div>Updated: {new Date(issue.updatedAt).toLocaleString()}</div>\n          </div>\n\n        </div>"
    }
