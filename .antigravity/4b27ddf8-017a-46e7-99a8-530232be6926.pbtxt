      replacement_content: "      {/* NEW PROJECT INLINE MODAL DIALOG */}\n      {isNewProjectOpen && (\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center bg-[#43423E]/45 backdrop-blur-xs\">\n          <div className=\"bg-white rounded-2xl shadow-xl border border-natural-border w-full max-w-md overflow-hidden animate-in fade-in zoom-in-95 duration-200\">\n            <div className=\"flex items-center justify-between px-6 py-4 bg-natural-sidebar text-natural-text-deep border-b border-natural-border\">\n              <h3 className=\"font-bold flex items-center gap-2\">\n                <Folder className=\"w-5 h-5 text-natural-primary\" /> Create New Agile Project\n              </h3>\n              <button \n                onClick={() => setIsNewProjectOpen(false)}\n                className=\"p-1 hover:bg-natural-hover-bg rounded-full transition-colors\"\n              >\n                <X className=\"w-5.5 h-5.5 text-natural-text-neutral\" />\n              </button>\n            </div>\n\n            <form onSubmit={handleCreateProjectSubmit} className=\"p-6 space-y-4 bg-natural-bg\">\n              {/* Project name */}\n              <div>\n                <label className=\"block text-xs font-semibold text-natural-text-neutral uppercase tracking-wider mb-1.5\">\n                  Project Name <span className=\"text-rose-500\">*</span>\n                </label>\n                <input\n                  type=\"text\"\n                  required\n                  placeholder=\"e.g. Billing Gateway Service\"\n                  value={newProjName}\n                  onChange={(e) => {\n                    setNewProjName(e.target.value);\n                    // Autofill Key if empty\n                    if (e.target.value.length >= 2 && !newProjKey) {\n                      const words = e.target.value.split(\" \");\n                      const keySuggestion = words.length > 1\n                        ? (words[0][0] + words[1][0]).toUpperCase()\n                        : e.target.value.substring(0, 3).toUpperCase();\n                      setNewProjKey(keySuggestion);\n                    }\n                  }}\n                  className=\"w-full px-3.5 py-2 text-sm border border-natural-border bg-white rounded-xl focus:outline-hidden focus:ring-2 focus:ring-natural-primary/20 focus:border-natural-primary\"\n                />\n              </div>\n\n              {/* Project key prefix */}\n              <div>\n                <label className=\"block text-xs font-semibold text-natural-text-neutral uppercase tracking-wider mb-1.5\">\n                  Project Key Prefix <span className=\"text-rose-500\">*</span>\n                </label>\n                <input\n                  type=\"text\"\n                  required\n                  maxLength={5}\n                  placeholder=\"e.g. BILL\"\n                  value={newProjKey}\n                  onChange={(e) => setNewProjKey(e.target.value.toUpperCase())}\n                  className=\"w-full px-3.5 py-2 text-sm border border-natural-border bg-white rounded-xl font-bold focus:outline-hidden focus:ring-2 focus:ring-natural-primary/20 focus:border-natural-primary\"\n                />\n                <p className=\"text-[10px] text-natural-text-light mt-1 font-medium\">\n                  Uppercase shortcode prefix used for issue keys (e.g. BILL-1, BILL-2)\n                </p>\n              </div>\n\n              {/* Project description */}\n              <div>\n                <label className=\"block text-xs font-semibold text-natural-text-neutral uppercase tracking-wider mb-1.5\">\n                  Description\n                </label>\n                <textarea\n                  placeholder=\"Summarize the core milestone objectives...\"\n                  value={newProjDesc}\n                  onChange={(e) => setNewProjDesc(e.target.value)}\n                  rows={2}\n                  className=\"w-full px-3.5 py-2 text-sm border border-natural-border bg-white rounded-xl focus:outline-hidden focus:ring-2 focus:ring-natural-primary/20\"\n                />\n              </div>\n\n              <div className=\"pt-4 flex items-center justify-end gap-3 border-t border-natural-border\">\n                <button\n                  type=\"button\"\n                  onClick={() => setIsNewProjectOpen(false)}\n                  className=\"px-4 py-2 text-sm font-semibold text-natural-text-neutral hover:text-natural-text-deep transition-colors\"\n                >\n                  Cancel\n                </button>\n                <button\n                  type=\"submit\"\n                  className=\"px-5 py-2 text-sm font-semibold bg-natural-primary hover:bg-natural-primary-hover text-white rounded-full shadow-xs transition-colors\"\n                >\n                  Create Project\n                </button>\n              </div>\n            </form>\n          </div>\n        </div>\n      )}"
    }
