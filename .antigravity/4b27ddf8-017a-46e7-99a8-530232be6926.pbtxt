    file_change_type: FILE_CHANGE_TYPE_EDIT
    replacement_chunks {
      target_content: "  return (\n    <div className=\"flex flex-col h-full bg-slate-50\" id=\"kanban-workspace\">\n      {/* Board Header Section */}\n      <div className=\"px-6 py-4 bg-white border-b border-slate-200 shadow-xs\">\n        <div className=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4\">\n          <div>\n            <div className=\"text-xs font-semibold text-slate-500 uppercase tracking-wider\">\n              Active Sprint\n            </div>\n            <h1 className=\"text-2xl font-bold text-slate-900 tracking-tight flex items-center gap-2\">\n              {activeSprint ? activeSprint.name : \"No Active Sprint\"}\n              {!activeSprint && (\n                <span className=\"text-xs font-normal px-2.5 py-0.5 rounded-full bg-amber-100 text-amber-800 border border-amber-200\">\n                  Plan Sprints in Backlog\n                </span>\n              )}\n            </h1>\n            {activeSprint?.goal && (\n              <p className=\"text-sm text-slate-500 mt-1 italic\">\n                Sprint Goal: {activeSprint.goal}\n              </p>\n            )}\n          </div>\n\n          <div className=\"flex items-center gap-3 self-end sm:self-center\">\n            <button\n              id=\"btn-quick-create\"\n              onClick={() => setIsQuickCreateOpen(true)}\n              className=\"flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md transition-colors shadow-xs\"\n            >\n              <Plus className=\"w-4 h-4\" /> Create Issue\n            </button>\n          </div>\n        </div>\n\n        {/* Filters and Search Bar */}\n        <div className=\"flex flex-wrap items-center gap-3 mt-6\">\n          {/* Search Input */}\n          <div className=\"relative w-64\">\n            <Search className=\"absolute left-3 top-2.5 w-4 h-4 text-slate-400\" />\n            <input\n              type=\"text\"\n              placeholder=\"Search issues, summary...\"\n              value={search}\n              onChange={(e) => setSearch(e.target.value)}\n              className=\"w-full pl-9 pr-4 py-2 text-sm bg-slate-100 border border-slate-200 rounded-md focus:outline-hidden focus:ring-2 focus:ring-blue-500/20 focus:bg-white transition-all\"\n            />\n          </div>\n\n          {/* Type Filter */}\n          <div className=\"flex items-center\">\n            <label className=\"text-xs font-medium text-slate-500 mr-2 uppercase\">Type:</label>\n            <select\n              value={selectedType}\n              onChange={(e) => setSelectedType(e.target.value)}\n              className=\"px-3 py-1.5 text-xs bg-white border border-slate-200 rounded-md text-slate-700 focus:ring-1 focus:ring-blue-500\"\n            >\n              <option value=\"All\">All Types</option>\n              <option value=\"Epic\">Epic</option>\n              <option value=\"Story\">Story</option>\n              <option value=\"Task\">Task</option>\n              <option value=\"Bug\">Bug</option>\n            </select>\n          </div>\n\n          {/* Assignee Filter */}\n          <div className=\"flex items-center\">\n            <label className=\"text-xs font-medium text-slate-500 mr-2 uppercase\">Assignee:</label>\n            <select\n              value={selectedAssignee}\n              onChange={(e) => setSelectedAssignee(e.target.value)}\n              className=\"px-3 py-1.5 text-xs bg-white border border-slate-200 rounded-md text-slate-700 focus:ring-1 focus:ring-blue-500\"\n            >\n              <option value=\"All\">All People</option>\n              {SEED_USERS.map((user) => (\n                <option key={user.email} value={user.name}>\n                  {user.name}\n                </option>\n              ))}\n            </select>\n          </div>\n\n          {/* Priority Filter */}\n          <div className=\"flex items-center\">\n            <label className=\"text-xs font-medium text-slate-500 mr-2 uppercase\">Priority:</label>\n            <select\n              value={selectedPriority}\n              onChange={(e) => setSelectedPriority(e.target.value)}\n              className=\"px-3 py-1.5 text-xs bg-white border border-slate-200 rounded-md text-slate-700 focus:ring-1 focus:ring-blue-500\"\n            >\n              <option value=\"All\">All Priorities</option>\n              <option value=\"Highest\">Highest</option>\n              <option value=\"High\">High</option>\n              <option value=\"Medium\">Medium</option>\n              <option value=\"Low\">Low</option>\n            </select>\n          </div>\n\n          {hasActiveFilters && (\n            <button\n              onClick={clearAllFilters}\n              className=\"text-xs text-blue-600 hover:text-blue-800 font-medium px-2 py-1.5 rounded hover:bg-slate-100 transition-colors\"\n            >\n              Clear Filters\n            </button>\n          )}\n\n          {/* Issue Counter stats */}\n          <div className=\"ml-auto text-xs text-slate-500 font-medium bg-slate-100 px-2.5 py-1.5 rounded-full\">\n            Showing <strong className=\"text-slate-700\">{filteredIssues.length}</strong> of {activeSprintIssues.length} active issues\n          </div>\n        </div>\n      </div>\n\n      {/* Grid of Board Columns */}\n      <div className=\"flex-1 overflow-x-auto p-6\">\n        <div className=\"flex gap-4 h-full min-w-[900px]\">\n          {COLUMNS.map((column) => {\n            const columnIssues = getIssuesByStatus(column);\n            const totalPoints = getStoryPointsSum(column);\n            \n            return (\n              <div\n                key={column}\n                id={`column-${column.toLowerCase().replace(\" \", \"-\")}`}\n                onDragOver={handleDragOver}\n                onDrop={(e) => handleDrop(e, column)}\n                className=\"flex-1 min-w-[250px] bg-slate-100 rounded-lg p-3 flex flex-col border border-slate-200 shadow-2xs\"\n              >\n                {/* Column Header */}\n                <div className=\"flex items-center justify-between mb-3 px-1\">\n                  <div className=\"flex items-center gap-2\">\n                    <span className=\"text-sm font-semibold text-slate-700\">{column}</span>\n                    <span className=\"text-xs bg-slate-200 text-slate-600 px-2 py-0.5 rounded-full font-bold\">\n                      {columnIssues.length}\n                    </span>\n                  </div>\n                  {totalPoints > 0 && (\n                    <span className=\"text-xs bg-blue-100 text-blue-700 font-semibold px-2 py-0.5 rounded-full\" title=\"Sum of Story Points\">\n                      {totalPoints} SP\n                    </span>\n                  )}\n                </div>\n\n                {/* Column Card Container */}\n                <div className=\"flex-1 space-y-2.5 overflow-y-auto max-h-[calc(100vh-290px)] scrollbar-thin\">\n                  {columnIssues.length === 0 ? (\n                    <div className=\"border-2 border-dashed border-slate-200 rounded-lg py-12 text-center text-slate-400 text-xs\">\n                      Drag issues here\n                    </div>\n                  ) : (\n                    columnIssues.map((issue) => (\n                      <div\n                        key={issue.id}\n                        draggable\n                        onDragStart={(e) => handleDragStart(e, issue.id)}\n                        onClick={() => onOpenIssueDetail(issue)}\n                        id={`issue-card-${issue.key}`}\n                        className=\"p-3.5 bg-white rounded-lg border border-slate-200 shadow-2xs hover:shadow-xs hover:border-blue-400 transition-all cursor-pointer group relative\"\n                      >\n                        {/* Issue Type, Key, and Priority */}\n                        <div className=\"flex items-center justify-between mb-2\">\n                          <div className=\"flex items-center gap-1.5\">\n                            {getIssueTypeIcon(issue.type)}\n                            <span className=\"text-xs font-bold text-slate-500 group-hover:text-blue-600 transition-colors\">\n                              {issue.key}\n                            </span>\n                          </div>\n                          <div className=\"flex items-center gap-1.5\">\n                            {getPriorityIcon(issue.priority)}\n                          </div>\n                        </div>\n\n                        {/* Issue Title */}\n                        <h4 className=\"text-sm font-medium text-slate-800 line-clamp-2 leading-tight mb-3\">\n                          {issue.summary}\n                        </h4>\n\n                        {/* Story Points & Assignee */}\n                        <div className=\"flex items-center justify-between pt-2 border-t border-slate-100\">\n                          {issue.storyPoints ? (\n                            <span className=\"text-[10px] font-bold px-2 py-0.5 bg-slate-100 border border-slate-200 text-slate-600 rounded-full\" title=\"Story Points\">\n                              {issue.storyPoints}\n                            </span>\n                          ) : (\n                            <span className=\"text-[10px] text-slate-400 italic\">No SP</span>\n                          )}\n\n                          <div className=\"flex items-center gap-2\">\n                            {issue.subtasks.length > 0 && (\n                              <span className=\"text-[10px] text-slate-500\" title=\"Sub-task progress\">\n                                {issue.subtasks.filter(s => s.completed).length}/{issue.subtasks.length} subtasks\n                              </span>\n                            )}\n                            <img\n                              src={issue.assignee.avatar}\n                              alt={issue.assignee.name}\n                              className=\"w-6 h-6 rounded-full ring-1 ring-slate-200 object-cover\"\n                              title={`Assigned to ${issue.assignee.name}`}\n                              referrerPolicy=\"no-referrer\"\n                            />\n                          </div>\n                        </div>\n\n                        {/* Quick state-selector overlay (visible on hover) for easy access */}\n                        <div className=\"absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity flex gap-1 bg-white p-0.5 rounded-md shadow-xs border border-slate-200\">\n                          <select\n                            onClick={(e) => e.stopPropagation()}\n                            value={issue.status}\n                            onChange={(e) => {\n                              e.stopPropagation();\n                              onUpdateIssueStatus(issue.id, e.target.value as IssueStatus);\n                            }}\n                            className=\"text-[10px] font-medium text-slate-600 bg-slate-50 border-0 focus:ring-0 cursor-pointer\"\n                          >\n                            {COLUMNS.map((col) => (\n                              <option key={col} value={col}>{col}</option>\n                            ))}\n                          </select>\n                        </div>\n                      </div>\n                    ))\n                  )}\n                </div>\n              </div>\n            );\n          })}\n        </div>\n      </div>"
      replacement_content: "  return (\n    <div className=\"flex flex-col h-full bg-natural-bg\" id=\"kanban-workspace\">\n      {/* Board Header Section */}\n      <div className=\"px-6 py-5 bg-white/40 backdrop-blur-sm border-b border-natural-border shadow-xs\">\n        <div className=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4\">\n          <div>\n            <div className=\"text-[10px] font-bold text-natural-text-light uppercase tracking-widest\">\n              Active Sprint Board\n            </div>\n            <h1 className=\"text-xl font-bold text-natural-text-deep tracking-tight flex items-center gap-2 mt-0.5\">\n              {activeSprint ? activeSprint.name : \"No Active Sprint\"}\n              {!activeSprint && (\n                <span className=\"text-[10px] font-semibold px-2 py-0.5 rounded-full bg-natural-sidebar text-natural-text-neutral border border-natural-border\">\n                  Plan Sprints in Backlog\n                </span>\n              )}\n            </h1>\n            {activeSprint?.goal && (\n              <p className=\"text-xs text-natural-text-neutral mt-1 italic font-medium\">\n                Sprint Goal: {activeSprint.goal}\n              </p>\n            )}\n          </div>\n\n          <div className=\"flex items-center gap-3 self-end sm:self-center\">\n            <button\n              id=\"btn-quick-create\"\n              onClick={() => setIsQuickCreateOpen(true)}\n              className=\"flex items-center gap-2 px-5 py-2 bg-natural-primary hover:bg-natural-primary-hover text-white text-sm font-medium rounded-full transition-all shadow-xs\"\n            >\n              <Plus className=\"w-4 h-4\" /> Create Issue\n            </button>\n          </div>\n        </div>\n\n        {/* Filters and Search Bar */}\n        <div className=\"flex flex-wrap items-center gap-3 mt-5\">\n          {/* Search Input */}\n          <div className=\"relative w-64\">\n            <Search className=\"absolute left-3.5 top-2.5 w-4 h-4 text-natural-text-light\" />\n            <input\n              type=\"text\"\n              placeholder=\"Search issues, summary...\"\n              value={search}\n              onChange={(e) => setSearch(e.target.value)}\n              className=\"w-full bg-natural-sidebar border border-natural-border rounded-full py-2 pl-10 pr-4 text-xs text-natural-text-deep focus:outline-hidden focus:ring-1 focus:ring-natural-primary focus:bg-white transition-all\"\n            />\n          </div>\n\n          {/* Type Filter */}\n          <div className=\"flex items-center\">\n            <label className=\"text-[10px] font-bold text-natural-text-light mr-2 uppercase tracking-wider\">Type:</label>\n            <select\n              value={selectedType}\n              onChange={(e) => setSelectedType(e.target.value)}\n              className=\"px-3 py-1.5 text-xs bg-white border border-natural-border rounded-xl text-natural-text-deep focus:outline-hidden focus:ring-1 focus:ring-natural-primary cursor-pointer shadow-2xs\"\n            >\n              <option value=\"All\">All Types</option>\n              <option value=\"Epic\">Epic</option>\n              <option value=\"Story\">Story</option>\n              <option value=\"Task\">Task</option>\n              <option value=\"Bug\">Bug</option>\n            </select>\n          </div>\n\n          {/* Assignee Filter */}\n          <div className=\"flex items-center\">\n            <label className=\"text-[10px] font-bold text-natural-text-light mr-2 uppercase tracking-wider\">Assignee:</label>\n            <select\n              value={selectedAssignee}\n              onChange={(e) => setSelectedAssignee(e.target.value)}\n              className=\"px-3 py-1.5 text-xs bg-white border border-natural-border rounded-xl text-natural-text-deep focus:outline-hidden focus:ring-1 focus:ring-natural-primary cursor-pointer shadow-2xs\"\n            >\n              <option value=\"All\">All People</option>\n              {SEED_USERS.map((user) => (\n                <option key={user.email} value={user.name}>\n                  {user.name}\n                </option>\n              ))}\n            </select>\n          </div>\n\n          {/* Priority Filter */}\n          <div className=\"flex items-center\">\n            <label className=\"text-[10px] font-bold text-natural-text-light mr-2 uppercase tracking-wider\">Priority:</label>\n            <select\n              value={selectedPriority}\n              onChange={(e) => setSelectedPriority(e.target.value)}\n              className=\"px-3 py-1.5 text-xs bg-white border border-natural-border rounded-xl text-natural-text-deep focus:outline-hidden focus:ring-1 focus:ring-natural-primary cursor-pointer shadow-2xs\"\n            >\n              <option value=\"All\">All Priorities</option>\n              <option value=\"Highest\">Highest</option>\n              <option value=\"High\">High</option>\n              <option value=\"Medium\">Medium</option>\n              <option value=\"Low\">Low</option>\n            </select>\n          </div>\n\n          {hasActiveFilters && (\n            <button\n              onClick={clearAllFilters}\n              className=\"text-xs text-natural-primary hover:text-natural-primary-hover font-bold px-3 py-1.5 rounded-xl hover:bg-natural-hover-bg transition-colors\"\n            >\n              Clear Filters\n            </button>\n          )}\n\n          {/* Issue Counter stats */}\n          <div className=\"ml-auto text-[10px] font-bold uppercase tracking-wider text-natural-text-light bg-natural-sidebar border border-natural-border px-3 py-1.5 rounded-full\">\n            Showing <strong className=\"text-natural-text-deep\">{filteredIssues.length}</strong> of {activeSprintIssues.length} active issues\n          </div>\n        </div>\n      </div>\n\n      {/* Grid of Board Columns */}\n      <div className=\"flex-1 overflow-x-auto p-6 bg-natural-bg\">\n        <div className=\"flex gap-5 h-full min-w-[900px]\">\n          {COLUMNS.map((column) => {\n            const columnIssues = getIssuesByStatus(column);\n            const totalPoints = getStoryPointsSum(column);\n            \n            return (\n              <div\n                key={column}\n                id={`column-${column.toLowerCase().replace(\" \", \"-\")}`}\n                onDragOver={handleDragOver}\n                onDrop={(e) => handleDrop(e, column)}\n                className=\"flex-1 min-w-[250px] bg-natural-sidebar rounded-2xl p-4 flex flex-col border border-natural-border shadow-2xs\"\n              >\n                {/* Column Header */}\n                <div className=\"flex items-center justify-between mb-4 px-1\">\n                  <div className=\"flex items-center gap-2\">\n                    <span className=\"text-xs font-bold uppercase tracking-widest text-natural-text-neutral\">{column}</span>\n                    <span className=\"text-[10px] bg-white text-natural-text-neutral px-2 py-0.5 rounded-full border border-natural-border font-bold\">\n                      {columnIssues.length}\n                    </span>\n                  </div>\n                  {totalPoints > 0 && (\n                    <span className=\"text-[10px] bg-natural-primary/10 border border-natural-primary/20 text-natural-primary font-bold px-2 py-0.5 rounded-full\" title=\"Sum of Story Points\">\n                      {totalPoints} SP\n                    </span>\n                  )}\n                </div>\n\n                {/* Column Card Container */}\n                <div className=\"flex-1 space-y-3 overflow-y-auto max-h-[calc(100vh-290px)] scrollbar-thin\">\n                  {columnIssues.length === 0 ? (\n                    <div className=\"border border-dashed border-natural-border bg-white/20 rounded-2xl py-12 text-center text-natural-text-light text-xs\">\n                      Drag issues here\n                    </div>\n                  ) : (\n                    columnIssues.map((issue) => {\n                      const isHighPriority = issue.priority === \"Highest\" || issue.priority === \"High\";\n                      const isDone = issue.status === \"Done\";\n                      \n                      return (\n                        <div\n                          key={issue.id}\n                          draggable\n                          onDragStart={(e) => handleDragStart(e, issue.id)}\n                          onClick={() => onOpenIssueDetail(issue)}\n                          id={`issue-card-${issue.key}`}\n                          className={`p-4 rounded-2xl border bg-white shadow-xs hover:border-natural-accent transition-all duration-200 cursor-pointer group relative ${\n                            isDone ? \"opacity-70 bg-natural-done-bg/50\" : \"\"\n                          } ${\n                            isHighPriority && !isDone ? \"border-l-4 border-l-natural-accent border-natural-border\" : \"border-natural-border\"\n                          }`}\n                        >\n                          {/* Issue Type, Key, and Priority */}\n                          <div className=\"flex items-center justify-between mb-2\">\n                            <div className=\"flex items-center gap-1.5\">\n                              {getIssueTypeIcon(issue.type)}\n                              <span className=\"text-[10px] font-bold text-natural-text-light group-hover:text-natural-primary transition-colors\">\n                                {issue.key}\n                              </span>\n                            </div>\n                            <div className=\"flex items-center gap-1.5\">\n                              {getPriorityIcon(issue.priority)}\n                            </div>\n                          </div>\n\n                          {/* Issue Title */}\n                          <h4 className={`text-sm font-semibold text-natural-text-deep leading-snug mb-3 ${isDone ? \"line-through text-natural-text-light\" : \"\"}`}>\n                            {issue.summary}\n                          </h4>\n\n                          {/* Story Points & Assignee */}\n                          <div className=\"flex items-center justify-between pt-2.5 border-t border-natural-border\">\n                            {issue.storyPoints ? (\n                              <span className=\"text-[10px] font-bold px-2 py-0.5 bg-natural-sidebar border border-natural-border text-natural-text-neutral rounded-full\" title=\"Story Points\">\n                                {issue.storyPoints}\n                              </span>\n                            ) : (\n                              <span className=\"text-[10px] text-natural-text-light italic\">No SP</span>\n                            )}\n\n                            <div className=\"flex items-center gap-2\">\n                              {issue.subtasks.length > 0 && (\n                                <span className=\"text-[9px] text-natural-text-light font-bold\" title=\"Sub-task progress\">\n                                  {issue.subtasks.filter(s => s.completed).length}/{issue.subtasks.length} subtasks\n                                </span>\n                              )}\n                              <img\n                                src={issue.assignee.avatar}\n                                alt={issue.assignee.name}\n                                className=\"w-5.5 h-5.5 rounded-full border border-white ring-2 ring-natural-sidebar object-cover\"\n                                title={`Assigned to ${issue.assignee.name}`}\n                                referrerPolicy=\"no-referrer\"\n                              />\n                            </div>\n                          </div>\n\n                          {/* Quick state-selector overlay (visible on hover) for easy access */}\n                          <div className=\"absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity flex gap-1 bg-white p-1 rounded-xl shadow-md border border-natural-border\">\n                            <select\n                              onClick={(e) => e.stopPropagation()}\n                              value={issue.status}\n                              onChange={(e) => {\n                                e.stopPropagation();\n                                onUpdateIssueStatus(issue.id, e.target.value as IssueStatus);\n                              }}\n                              className=\"text-[10px] font-semibold text-natural-text-deep bg-natural-sidebar border-0 focus:ring-0 cursor-pointer rounded-lg px-1.5 py-0.5\"\n                            >\n                              {COLUMNS.map((col) => (\n                                <option key={col} value={col}>{col}</option>\n                              ))}\n                            </select>\n                          </div>\n                        </div>\n                      );\n                    })\n                  )}\n                </div>\n              </div>\n            );\n          })}\n        </div>\n      </div>"
    }
