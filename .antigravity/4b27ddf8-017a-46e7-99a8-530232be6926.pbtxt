    file_change_type: FILE_CHANGE_TYPE_EDIT
    replacement_chunks {
      target_content: "  return (\n    <div className=\"flex-1 overflow-y-auto bg-slate-50 p-6 scrollbar-thin\" id=\"insights-workspace\">\n      \n      {/* Page Header */}\n      <div className=\"max-w-5xl mx-auto w-full mb-6\">\n        <div className=\"text-xs font-semibold text-slate-500 uppercase tracking-wider flex items-center gap-1\">\n          <BarChart2 className=\"w-3.5 h-3.5 text-slate-400\" /> Metrics & Analytics\n        </div>\n        <h1 className=\"text-2xl font-bold text-slate-900 tracking-tight\">\n          Agile Insights Dashboard\n        </h1>\n        <p className=\"text-xs text-slate-500 mt-1\">\n          Review overall project velocity, resource allocation ratios, and developer work log diagnostics.\n        </p>\n      </div>\n\n      <div className=\"max-w-5xl mx-auto w-full space-y-6\">\n\n        {/* 1. AGGREGATE SUMMARY CARDS GRID */}\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n          <div className=\"bg-white rounded-xl border border-slate-200 p-4 shadow-2xs flex items-center gap-4\">\n            <div className=\"p-3 bg-blue-50 text-blue-600 rounded-lg\">\n              <BarChart2 className=\"w-5 h-5\" />\n            </div>\n            <div>\n              <div className=\"text-[10px] font-bold text-slate-500 uppercase\">Total Scope</div>\n              <div className=\"text-xl font-bold text-slate-900\">{totalPoints} Story Points</div>\n              <div className=\"text-[10px] text-slate-400 font-medium\">{projectIssues.length} issues tracked</div>\n            </div>\n          </div>\n\n          <div className=\"bg-white rounded-xl border border-slate-200 p-4 shadow-2xs flex items-center gap-4\">\n            <div className=\"p-3 bg-emerald-50 text-emerald-600 rounded-lg\">\n              <CheckCircle2 className=\"w-5 h-5\" />\n            </div>\n            <div>\n              <div className=\"text-[10px] font-bold text-slate-500 uppercase\">Completed Points</div>\n              <div className=\"text-xl font-bold text-slate-900\">{donePoints} Story Points</div>\n              <div className=\"text-[10px] text-emerald-600 font-semibold\">\n                {totalPoints > 0 ? Math.round((donePoints / totalPoints) * 100) : 0}% completion velocity\n              </div>\n            </div>\n          </div>\n\n          <div className=\"bg-white rounded-xl border border-slate-200 p-4 shadow-2xs flex items-center gap-4\">\n            <div className=\"p-3 bg-amber-50 text-amber-600 rounded-lg\">\n              <Clock className=\"w-5 h-5\" />\n            </div>\n            <div>\n              <div className=\"text-[10px] font-bold text-slate-500 uppercase\">Logged Effort</div>\n              <div className=\"text-xl font-bold text-slate-900\">{totalHoursLogged} Hours</div>\n              <div className=\"text-[10px] text-slate-400 font-medium\">{allWorkLogs.length} audit sessions</div>\n            </div>\n          </div>\n\n          <div className=\"bg-white rounded-xl border border-slate-200 p-4 shadow-2xs flex items-center gap-4\">\n            <div className=\"p-3 bg-purple-50 text-purple-600 rounded-lg\">\n              <Users className=\"w-5 h-5\" />\n            </div>\n            <div>\n              <div className=\"text-[10px] font-bold text-slate-500 uppercase\">Active Sprints</div>\n              <div className=\"text-xl font-bold text-slate-900\">{projectSprints.length} Planned</div>\n              <div className=\"text-[10px] text-purple-600 font-semibold\">\n                {projectSprints.filter(s => s.status === \"active\").length} active sprint running\n              </div>\n            </div>\n          </div>\n        </div>\n\n        {/* 2. SPRINT BURNUP CHART & SCOPE RANGES */}\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n          \n          {/* Active Sprint Burnup progress bar distribution */}\n          <div className=\"bg-white rounded-xl border border-slate-200 p-5 shadow-xs flex flex-col justify-between\">\n            <div>\n              <h3 className=\"font-bold text-slate-900 text-sm mb-1\">Sprint Progress Bar</h3>\n              <p className=\"text-xs text-slate-400 mb-4\">Percentage breakdown of story points inside all tracked columns.</p>\n            </div>\n\n            <div className=\"space-y-4\">\n              {/* Giant composite bar */}\n              <div className=\"h-6 w-full rounded-full overflow-hidden flex bg-slate-100 border border-slate-200\">\n                {donePoints > 0 && (\n                  <div\n                    style={{ width: `${(donePoints / (totalPoints || 1)) * 100}%` }}\n                    className=\"h-full bg-emerald-500 transition-all\"\n                    title={`Done: ${donePoints} SP`}\n                  />\n                )}\n                {progressPoints > 0 && (\n                  <div\n                    style={{ width: `${(progressPoints / (totalPoints || 1)) * 100}%` }}\n                    className=\"h-full bg-blue-500 transition-all\"\n                    title={`In Progress & Review: ${progressPoints} SP`}\n                  />\n                )}\n                {todoPoints > 0 && (\n                  <div\n                    style={{ width: `${(todoPoints / (totalPoints || 1)) * 100}%` }}\n                    className=\"h-full bg-slate-300 transition-all\"\n                    title={`To Do & Backlog: ${todoPoints} SP`}\n                  />\n                )}\n              </div>\n\n              {/* Legends with direct counts */}\n              <div className=\"grid grid-cols-3 gap-2.5 text-xs text-slate-600\">\n                <div className=\"flex items-center gap-1.5 p-2 bg-emerald-50 rounded border border-emerald-100\">\n                  <span className=\"w-2.5 h-2.5 rounded-full bg-emerald-500\" />\n                  <div>\n                    <span className=\"block font-semibold text-emerald-800\">Done</span>\n                    <strong className=\"text-emerald-950 font-bold\">{donePoints} SP</strong>\n                  </div>\n                </div>\n\n                <div className=\"flex items-center gap-1.5 p-2 bg-blue-50 rounded border border-blue-100\">\n                  <span className=\"w-2.5 h-2.5 rounded-full bg-blue-500\" />\n                  <div>\n                    <span className=\"block font-semibold text-blue-800\">Active</span>\n                    <strong className=\"text-blue-950 font-bold\">{progressPoints} SP</strong>\n                  </div>\n                </div>\n\n                <div className=\"flex items-center gap-1.5 p-2 bg-slate-100 rounded border border-slate-200\">\n                  <span className=\"w-2.5 h-2.5 rounded-full bg-slate-400\" />\n                  <div>\n                    <span className=\"block font-semibold text-slate-700\">Planned</span>\n                    <strong className=\"text-slate-950 font-bold\">{todoPoints} SP</strong>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          {/* Issue Type Distribution Donut SVG */}\n          <div className=\"bg-white rounded-xl border border-slate-200 p-5 shadow-xs flex flex-col md:flex-row md:items-center gap-6\">\n            <div className=\"flex-1\">\n              <h3 className=\"font-bold text-slate-900 text-sm mb-1\">Issue Types</h3>\n              <p className=\"text-xs text-slate-400 mb-4\">Visual breakdown of scope profile.</p>\n\n              {/* Donut Legend */}\n              <div className=\"space-y-2 text-xs\">\n                <div className=\"flex items-center justify-between\">\n                  <div className=\"flex items-center gap-1.5 text-slate-600\">\n                    <span className=\"w-3 h-3 bg-purple-500 rounded-sm\" />\n                    <span>Epic Tasks</span>\n                  </div>\n                  <strong className=\"text-slate-900\">{epics.length} ({epicPct}%)</strong>\n                </div>\n\n                <div className=\"flex items-center justify-between\">\n                  <div className=\"flex items-center gap-1.5 text-slate-600\">\n                    <span className=\"w-3 h-3 bg-emerald-500 rounded-sm\" />\n                    <span>User Stories</span>\n                  </div>\n                  <strong className=\"text-slate-900\">{stories.length} ({storyPct}%)</strong>\n                </div>\n\n                <div className=\"flex items-center justify-between\">\n                  <div className=\"flex items-center gap-1.5 text-slate-600\">\n                    <span className=\"w-3 h-3 bg-blue-500 rounded-sm\" />\n                    <span>Engineering Tasks</span>\n                  </div>\n                  <strong className=\"text-slate-900\">{tasks.length} ({taskPct}%)</strong>\n                </div>\n\n                <div className=\"flex items-center justify-between\">\n                  <div className=\"flex items-center gap-1.5 text-slate-600\">\n                    <span className=\"w-3 h-3 bg-rose-500 rounded-sm\" />\n                    <span>Defects / Bugs</span>\n                  </div>\n                  <strong className=\"text-slate-900\">{bugs.length} ({bugPct}%)</strong>\n                </div>\n              </div>\n            </div>\n\n            {/* SVG Interactive Donut drawing */}\n            <div className=\"w-32 h-32 mx-auto shrink-0 flex items-center justify-center relative\">\n              <svg className=\"w-full h-full transform -rotate-90\" viewBox=\"0 0 42 42\">\n                {/* Background circle */}\n                <circle cx=\"21\" cy=\"21\" r=\"15.915\" fill=\"transparent\" stroke=\"#f1f5f9\" strokeWidth=\"6\" />\n\n                {/* Bug segment */}\n                <circle\n                  cx=\"21\" cy=\"21\" r=\"15.915\"\n                  fill=\"transparent\"\n                  stroke=\"#ef4444\"\n                  strokeWidth=\"6\"\n                  strokeDasharray={`${bugPct} ${100 - bugPct}`}\n                  strokeDashoffset=\"0\"\n                />\n\n                {/* Task segment */}\n                <circle\n                  cx=\"21\" cy=\"21\" r=\"15.915\"\n                  fill=\"transparent\"\n                  stroke=\"#3b82f6\"\n                  strokeWidth=\"6\"\n                  strokeDasharray={`${taskPct} ${100 - taskPct}`}\n                  strokeDashoffset={-bugPct}\n                />\n\n                {/* Story segment */}\n                <circle\n                  cx=\"21\" cy=\"21\" r=\"15.915\"\n                  fill=\"transparent\"\n                  stroke=\"#10b981\"\n                  strokeWidth=\"6\"\n                  strokeDasharray={`${storyPct} ${100 - storyPct}`}\n                  strokeDashoffset={-(bugPct + taskPct)}\n                />\n\n                {/* Epic segment */}\n                <circle\n                  cx=\"21\" cy=\"21\" r=\"15.915\"\n                  fill=\"transparent\"\n                  stroke=\"#a855f7\"\n                  strokeWidth=\"6\"\n                  strokeDasharray={`${epicPct} ${100 - epicPct}`}\n                  strokeDashoffset={-(bugPct + taskPct + storyPct)}\n                />\n              </svg>\n              {/* Inner core display */}\n              <div className=\"absolute text-center\">\n                <span className=\"block text-xl font-extrabold text-slate-800\">{projectIssues.length}</span>\n                <span className=\"text-[9px] text-slate-400 font-bold uppercase tracking-wider\">Issues</span>\n              </div>\n            </div>\n\n          </div>\n\n        </div>\n\n        {/* 3. VELOCITY BAR GRAPH (SVG COMPOSITE) */}\n        <div className=\"bg-white rounded-xl border border-slate-200 p-5 shadow-xs\">\n          <h3 className=\"font-bold text-slate-900 text-sm mb-1\">Sprint Velocity & Estimates</h3>\n          <p className=\"text-xs text-slate-400 mb-6\">Comparison of total story points in each planned and active sprint, showing Done vs Total.</p>\n\n          <div className=\"space-y-4\">\n            {velocityData.length === 0 ? (\n              <p className=\"text-xs text-slate-400 italic\">Plan sprints in the Backlog to populate velocity tracking.</p>\n            ) : (\n              velocityData.map((data, index) => {\n                const percentageDone = data.totalPoints > 0 ? (data.donePoints / data.totalPoints) * 100 : 0;\n                \n                return (\n                  <div key={index} className=\"space-y-1.5 text-xs\">\n                    <div className=\"flex items-center justify-between font-semibold\">\n                      <span className=\"text-slate-800\">{data.name} ({data.status})</span>\n                      <span className=\"text-slate-500\">\n                        <strong className=\"text-slate-900 font-bold\">{data.donePoints} SP</strong> / {data.totalPoints} SP done\n                      </span>\n                    </div>\n\n                    <div className=\"h-4.5 w-full bg-slate-100 rounded-md overflow-hidden relative border border-slate-200 shadow-2xs\">\n                      {/* total points range bar background */}\n                      <div\n                        style={{ width: `${Math.min(100, (data.totalPoints / 30) * 100)}%` }}\n                        className=\"h-full bg-slate-200\"\n                      >\n                        {/* done segment */}\n                        <div\n                          style={{ width: `${percentageDone}%` }}\n                          className=\"h-full bg-emerald-500\"\n                        />\n                      </div>\n\n                      {/* fallback text */}\n                      {data.totalPoints === 0 && (\n                        <span className=\"absolute inset-0 flex items-center justify-center text-[10px] text-slate-400\">0 story points planned</span>\n                      )}\n                    </div>\n                  </div>\n                );\n              })\n            )}\n          </div>\n        </div>\n\n        {/* 4. CHRONICLED WORK LOG TABLE */}\n        <div className=\"bg-white rounded-xl border border-slate-200 overflow-hidden shadow-xs\">\n          <div className=\"px-5 py-4 border-b border-slate-200 bg-slate-900 text-white flex items-center justify-between\">\n            <div>\n              <h3 className=\"font-bold text-sm\">Work Log Diagnostic Audit</h3>\n              <p className=\"text-[10px] text-slate-300\">Detailed logs submitted by team developers</p>\n            </div>\n            <span className=\"text-xs bg-emerald-600 font-bold px-2.5 py-0.5 rounded-full text-white\">\n              {totalHoursLogged} Hrs Logged\n            </span>\n          </div>\n\n          {allWorkLogs.length === 0 ? (\n            <div className=\"p-8 text-center text-xs text-slate-400 italic bg-white\">\n              No work hours have been logged yet. Open an issue drawer to log development hours!\n            </div>\n          ) : (\n            <div className=\"overflow-x-auto\">\n              <table className=\"w-full text-left border-collapse text-xs\">\n                <thead>\n                  <tr className=\"bg-slate-50 border-b border-slate-200 text-slate-500 font-bold\">\n                    <th className=\"p-3\">Issue</th>\n                    <th className=\"p-3\">Developer</th>\n                    <th className=\"p-3\">Logged Time</th>\n                    <th className=\"p-3\">Activity Description</th>\n                    <th className=\"p-3 text-right\">Date</th>\n                  </tr>\n                </thead>\n                <tbody className=\"divide-y divide-slate-100\">\n                  {allWorkLogs.map((log) => (\n                    <tr key={log.id} className=\"hover:bg-slate-50/50 transition-colors\">\n                      <td className=\"p-3 font-semibold text-blue-600 whitespace-nowrap\">\n                        {log.issueKey}\n                      </td>\n                      <td className=\"p-3 font-bold text-slate-800\">\n                        {log.author}\n                      </td>\n                      <td className=\"p-3\">\n                        <span className=\"px-2 py-0.5 bg-emerald-100 border border-emerald-200 text-emerald-800 font-bold rounded\">\n                          {log.hoursLogged} hours\n                        </span>\n                      </td>\n                      <td className=\"p-3 text-slate-600 italic\">\n                        \"{log.description}\"\n                      </td>\n                      <td className=\"p-3 text-slate-400 text-right whitespace-nowrap\">\n                        {new Date(log.createdAt).toLocaleDateString()}\n                      </td>\n                    </tr>\n                  ))}\n                </tbody>\n              </table>\n            </div>\n          )}\n        </div>\n\n      </div>\n    </div>\n  );"
      replacement_content: "  return (\n    <div className=\"flex-1 overflow-y-auto bg-natural-bg p-6 scrollbar-thin\" id=\"insights-workspace\">\n      \n      {/* Page Header */}\n      <div className=\"max-w-5xl mx-auto w-full mb-6\">\n        <div className=\"text-xs font-bold text-natural-primary uppercase tracking-widest flex items-center gap-1\">\n          <BarChart2 className=\"w-3.5 h-3.5 text-natural-primary\" /> Metrics & Analytics\n        </div>\n        <h1 className=\"text-2xl font-bold text-natural-text-deep tracking-tight mt-1\">\n          Agile Insights Dashboard\n        </h1>\n        <p className=\"text-xs text-natural-text-neutral mt-1\">\n          Review overall project velocity, resource allocation ratios, and developer work log diagnostics.\n        </p>\n      </div>\n\n      <div className=\"max-w-5xl mx-auto w-full space-y-6\">\n\n        {/* 1. AGGREGATE SUMMARY CARDS GRID */}\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n          <div className=\"bg-white rounded-2xl border border-natural-border p-5 shadow-2xs flex items-center gap-4\">\n            <div className=\"p-3 bg-natural-primary/10 text-natural-primary rounded-xl\">\n              <BarChart2 className=\"w-5 h-5\" />\n            </div>\n            <div>\n              <div className=\"text-[10px] font-bold text-natural-text-neutral uppercase tracking-wider mb-1\">Total Scope</div>\n              <div className=\"text-lg font-bold text-natural-text-deep\">{totalPoints} Story Points</div>\n              <div className=\"text-[10px] text-natural-text-light font-medium\">{projectIssues.length} issues tracked</div>\n            </div>\n          </div>\n\n          <div className=\"bg-white rounded-2xl border border-natural-border p-5 shadow-2xs flex items-center gap-4\">\n            <div className=\"p-3 bg-natural-primary/10 text-natural-primary rounded-xl\">\n              <CheckCircle2 className=\"w-5 h-5\" />\n            </div>\n            <div>\n              <div className=\"text-[10px] font-bold text-natural-text-neutral uppercase tracking-wider mb-1\">Completed Points</div>\n              <div className=\"text-lg font-bold text-natural-text-deep\">{donePoints} Story Points</div>\n              <div className=\"text-[10px] text-natural-primary font-bold\">\n                {totalPoints > 0 ? Math.round((donePoints / totalPoints) * 100) : 0}% completion velocity\n              </div>\n            </div>\n          </div>\n\n          <div className=\"bg-white rounded-2xl border border-natural-border p-5 shadow-2xs flex items-center gap-4\">\n            <div className=\"p-3 bg-natural-primary/10 text-natural-primary rounded-xl\">\n              <Clock className=\"w-5 h-5\" />\n            </div>\n            <div>\n              <div className=\"text-[10px] font-bold text-natural-text-neutral uppercase tracking-wider mb-1\">Logged Effort</div>\n              <div className=\"text-lg font-bold text-natural-text-deep\">{totalHoursLogged} Hours</div>\n              <div className=\"text-[10px] text-natural-text-light font-medium\">{allWorkLogs.length} audit sessions</div>\n            </div>\n          </div>\n\n          <div className=\"bg-white rounded-2xl border border-natural-border p-5 shadow-2xs flex items-center gap-4\">\n            <div className=\"p-3 bg-natural-primary/10 text-natural-primary rounded-xl\">\n              <Users className=\"w-5 h-5\" />\n            </div>\n            <div>\n              <div className=\"text-[10px] font-bold text-natural-text-neutral uppercase tracking-wider mb-1\">Active Sprints</div>\n              <div className=\"text-lg font-bold text-natural-text-deep\">{projectSprints.length} Planned</div>\n              <div className=\"text-[10px] text-natural-accent font-bold\">\n                {projectSprints.filter(s => s.status === \"active\").length} active sprint running\n              </div>\n            </div>\n          </div>\n        </div>\n\n        {/* 2. SPRINT BURNUP CHART & SCOPE RANGES */}\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n          \n          {/* Active Sprint Burnup progress bar distribution */}\n          <div className=\"bg-white rounded-2xl border border-natural-border p-6 shadow-2xs flex flex-col justify-between\">\n            <div>\n              <h3 className=\"font-bold text-natural-text-deep text-sm mb-1\">Sprint Progress Bar</h3>\n              <p className=\"text-xs text-natural-text-neutral mb-4 leading-relaxed\">Percentage breakdown of story points inside all tracked columns.</p>\n            </div>\n\n            <div className=\"space-y-4\">\n              {/* Giant composite bar */}\n              <div className=\"h-6 w-full rounded-full overflow-hidden flex bg-natural-sidebar border border-natural-border/60\">\n                {donePoints > 0 && (\n                  <div\n                    style={{ width: `${(donePoints / (totalPoints || 1)) * 100}%` }}\n                    className=\"h-full bg-natural-primary transition-all\"\n                    title={`Done: ${donePoints} SP`}\n                  />\n                )}\n                {progressPoints > 0 && (\n                  <div\n                    style={{ width: `${(progressPoints / (totalPoints || 1)) * 100}%` }}\n                    className=\"h-full bg-natural-accent transition-all\"\n                    title={`In Progress & Review: ${progressPoints} SP`}\n                  />\n                )}\n                {todoPoints > 0 && (\n                  <div\n                    style={{ width: `${(todoPoints / (totalPoints || 1)) * 100}%` }}\n                    className=\"h-full bg-natural-border transition-all\"\n                    title={`To Do & Backlog: ${todoPoints} SP`}\n                  />\n                )}\n              </div>\n\n              {/* Legends with direct counts */}\n              <div className=\"grid grid-cols-3 gap-2.5 text-xs\">\n                <div className=\"flex items-center gap-1.5 p-2 bg-natural-primary/10 rounded-xl border border-natural-primary/20\">\n                  <span className=\"w-2.5 h-2.5 rounded-full bg-natural-primary\" />\n                  <div>\n                    <span className=\"block font-bold text-natural-primary\">Done</span>\n                    <strong className=\"text-natural-text-deep font-bold\">{donePoints} SP</strong>\n                  </div>\n                </div>\n\n                <div className=\"flex items-center gap-1.5 p-2 bg-natural-accent/10 rounded-xl border border-natural-accent/20\">\n                  <span className=\"w-2.5 h-2.5 rounded-full bg-natural-accent\" />\n                  <div>\n                    <span className=\"block font-bold text-natural-accent\">Active</span>\n                    <strong className=\"text-natural-text-deep font-bold\">{progressPoints} SP</strong>\n                  </div>\n                </div>\n\n                <div className=\"flex items-center gap-1.5 p-2 bg-natural-sidebar rounded-xl border border-natural-border\">\n                  <span className=\"w-2.5 h-2.5 rounded-full bg-natural-text-light\" />\n                  <div>\n                    <span className=\"block font-bold text-natural-text-neutral\">Planned</span>\n                    <strong className=\"text-natural-text-deep font-bold\">{todoPoints} SP</strong>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          {/* Issue Type Distribution Donut SVG */}\n          <div className=\"bg-white rounded-2xl border border-natural-border p-6 shadow-2xs flex flex-col md:flex-row md:items-center gap-6\">\n            <div className=\"flex-1\">\n              <h3 className=\"font-bold text-natural-text-deep text-sm mb-1\">Issue Types</h3>\n              <p className=\"text-xs text-natural-text-neutral mb-4 leading-relaxed\">Visual breakdown of scope profile.</p>\n\n              {/* Donut Legend */}\n              <div className=\"space-y-2 text-xs\">\n                <div className=\"flex items-center justify-between\">\n                  <div className=\"flex items-center gap-1.5 text-natural-text-neutral font-medium\">\n                    <span className=\"w-3 h-3 bg-natural-text-deep rounded-sm\" />\n                    <span>Epic Tasks</span>\n                  </div>\n                  <strong className=\"text-natural-text-deep font-bold\">{epics.length} ({epicPct}%)</strong>\n                </div>\n\n                <div className=\"flex items-center justify-between\">\n                  <div className=\"flex items-center gap-1.5 text-natural-text-neutral font-medium\">\n                    <span className=\"w-3 h-3 bg-natural-primary rounded-sm\" />\n                    <span>User Stories</span>\n                  </div>\n                  <strong className=\"text-natural-text-deep font-bold\">{stories.length} ({storyPct}%)</strong>\n                </div>\n\n                <div className=\"flex items-center justify-between\">\n                  <div className=\"flex items-center gap-1.5 text-natural-text-neutral font-medium\">\n                    <span className=\"w-3 h-3 bg-natural-accent rounded-sm\" />\n                    <span>Engineering Tasks</span>\n                  </div>\n                  <strong className=\"text-natural-text-deep font-bold\">{tasks.length} ({taskPct}%)</strong>\n                </div>\n\n                <div className=\"flex items-center justify-between\">\n                  <div className=\"flex items-center gap-1.5 text-natural-text-neutral font-medium\">\n                    <span className=\"w-3 h-3 bg-rose-500 rounded-sm\" />\n                    <span>Defects / Bugs</span>\n                  </div>\n                  <strong className=\"text-natural-text-deep font-bold\">{bugs.length} ({bugPct}%)</strong>\n                </div>\n              </div>\n            </div>\n\n            {/* SVG Interactive Donut drawing */}\n            <div className=\"w-32 h-32 mx-auto shrink-0 flex items-center justify-center relative\">\n              <svg className=\"w-full h-full transform -rotate-90\" viewBox=\"0 0 42 42\">\n                {/* Background circle */}\n                <circle cx=\"21\" cy=\"21\" r=\"15.915\" fill=\"transparent\" stroke=\"var(--color-natural-sidebar)\" strokeWidth=\"6\" />\n\n                {/* Bug segment */}\n                <circle\n                  cx=\"21\" cy=\"21\" r=\"15.915\"\n                  fill=\"transparent\"\n                  stroke=\"#ef4444\"\n                  strokeWidth=\"6\"\n                  strokeDasharray={`${bugPct} ${100 - bugPct}`}\n                  strokeDashoffset=\"0\"\n                />\n\n                {/* Task segment */}\n                <circle\n                  cx=\"21\" cy=\"21\" r=\"15.915\"\n                  fill=\"transparent\"\n                  stroke=\"var(--color-natural-accent)\"\n                  strokeWidth=\"6\"\n                  strokeDasharray={`${taskPct} ${100 - taskPct}`}\n                  strokeDashoffset={-bugPct}\n                />\n\n                {/* Story segment */}\n                <circle\n                  cx=\"21\" cy=\"21\" r=\"15.915\"\n                  fill=\"transparent\"\n                  stroke=\"var(--color-natural-primary)\"\n                  strokeWidth=\"6\"\n                  strokeDasharray={`${storyPct} ${100 - storyPct}`}\n                  strokeDashoffset={-(bugPct + taskPct)}\n                />\n\n                {/* Epic segment */}\n                <circle\n                  cx=\"21\" cy=\"21\" r=\"15.915\"\n                  fill=\"transparent\"\n                  stroke=\"var(--color-natural-text-deep)\"\n                  strokeWidth=\"6\"\n                  strokeDasharray={`${epicPct} ${100 - epicPct}`}\n                  strokeDashoffset={-(bugPct + taskPct + storyPct)}\n                />\n              </svg>\n              {/* Inner core display */}\n              <div className=\"absolute text-center\">\n                <span className=\"block text-xl font-extrabold text-natural-text-deep\">{projectIssues.length}</span>\n                <span className=\"text-[9px] text-natural-text-neutral font-bold uppercase tracking-wider\">Issues</span>\n              </div>\n            </div>\n\n          </div>\n\n        </div>\n\n        {/* 3. VELOCITY BAR GRAPH (SVG COMPOSITE) */}\n        <div className=\"bg-white rounded-2xl border border-natural-border p-6 shadow-2xs\">\n          <h3 className=\"font-bold text-natural-text-deep text-sm mb-1\">Sprint Velocity & Estimates</h3>\n          <p className=\"text-xs text-natural-text-neutral mb-6 leading-relaxed\">Comparison of total story points in each planned and active sprint, showing Done vs Total.</p>\n\n          <div className=\"space-y-4\">\n            {velocityData.length === 0 ? (\n              <p className=\"text-xs text-natural-text-light italic\">Plan sprints in the Backlog to populate velocity tracking.</p>\n            ) : (\n              velocityData.map((data, index) => {\n                const percentageDone = data.totalPoints > 0 ? (data.donePoints / data.totalPoints) * 100 : 0;\n                \n                return (\n                  <div key={index} className=\"space-y-1.5 text-xs\">\n                    <div className=\"flex items-center justify-between font-semibold\">\n                      <span className=\"text-natural-text-deep font-bold\">{data.name} ({data.status})</span>\n                      <span className=\"text-natural-text-neutral\">\n                        <strong className=\"text-natural-primary font-bold\">{data.donePoints} SP</strong> / {data.totalPoints} SP done\n                      </span>\n                    </div>\n\n                    <div className=\"h-4.5 w-full bg-natural-sidebar rounded-full overflow-hidden relative border border-natural-border/60\">\n                      {/* total points range bar background */}\n                      <div\n                        style={{ width: `${Math.min(100, (data.totalPoints / 30) * 100)}%` }}\n                        className=\"h-full bg-natural-border/40\"\n                      >\n                        {/* done segment */}\n                        <div\n                          style={{ width: `${percentageDone}%` }}\n                          className=\"h-full bg-natural-primary\"\n                        />\n                      </div>\n\n                      {/* fallback text */}\n                      {data.totalPoints === 0 && (\n                        <span className=\"absolute inset-0 flex items-center justify-center text-[10px] text-natural-text-light font-medium\">0 story points planned</span>\n                      )}\n                    </div>\n                  </div>\n                );\n              })\n            )}\n          </div>\n        </div>\n\n        {/* 4. CHRONICLED WORK LOG TABLE */}\n        <div className=\"bg-white rounded-2xl border border-natural-border overflow-hidden shadow-2xs\">\n          <div className=\"px-5 py-4.5 border-b border-natural-border bg-natural-sidebar text-natural-text-deep flex items-center justify-between\">\n            <div>\n              <h3 className=\"font-bold text-sm tracking-tight text-natural-text-deep\">Work Log Diagnostic Audit</h3>\n              <p className=\"text-[10px] text-natural-text-neutral font-medium\">Detailed logs submitted by team developers</p>\n            </div>\n            <span className=\"text-xs bg-natural-primary font-bold px-3.5 py-1.5 rounded-full text-white shadow-xs\">\n              {totalHoursLogged} Hrs Logged\n            </span>\n          </div>\n\n          {allWorkLogs.length === 0 ? (\n            <div className=\"p-8 text-center text-xs text-natural-text-light italic bg-white\">\n              No work hours have been logged yet. Open an issue drawer to log development hours!\n            </div>\n          ) : (\n            <div className=\"overflow-x-auto\">\n              <table className=\"w-full text-left border-collapse text-xs\">\n                <thead>\n                  <tr className=\"bg-natural-sidebar border-b border-natural-border text-natural-text-neutral font-bold uppercase tracking-wider text-[10px]\">\n                    <th className=\"p-3.5\">Issue</th>\n                    <th className=\"p-3.5\">Developer</th>\n                    <th className=\"p-3.5\">Logged Time</th>\n                    <th className=\"p-3.5\">Activity Description</th>\n                    <th className=\"p-3.5 text-right\">Date</th>\n                  </tr>\n                </thead>\n                <tbody className=\"divide-y divide-natural-border/40\">\n                  {allWorkLogs.map((log) => (\n                    <tr key={log.id} className=\"hover:bg-natural-hover-bg/30 transition-colors\">\n                      <td className=\"p-3.5 font-bold text-natural-primary whitespace-nowrap\">\n                        {log.issueKey}\n                      </td>\n                      <td className=\"p-3.5 font-bold text-natural-text-deep\">\n                        {log.author}\n                      </td>\n                      <td className=\"p-3.5\">\n                        <span className=\"px-2.5 py-0.5 bg-natural-primary/10 border border-natural-primary/20 text-natural-primary font-bold rounded-full\">\n                          {log.hoursLogged} hours\n                        </span>\n                      </td>\n                      <td className=\"p-3.5 text-natural-text-neutral italic\">\n                        \"{log.description}\"\n                      </td>\n                      <td className=\"p-3.5 text-natural-text-light text-right whitespace-nowrap\">\n                        {new Date(log.createdAt).toLocaleDateString()}\n                      </td>\n                    </tr>\n                  ))}\n                </tbody>\n              </table>\n            </div>\n          )}\n        </div>\n\n      </div>\n    </div>\n  );"
    }
