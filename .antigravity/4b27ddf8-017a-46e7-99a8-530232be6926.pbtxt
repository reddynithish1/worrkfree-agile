b-3 ${isDone ? \"line-through text-natural-text-light\" : \"\"}`}>\n                            {issue.summary}\n                          </h4>\n\n                          {/* Story Points & Assignee */}\n                          <div className=\"flex items-center justify-between pt-2.5 border-t border-natural-border\">\n                            {issue.storyPoints ? (\n                              <span className=\"text-[10px] font-bold px-2 py-0.5 bg-natural-sidebar border border-natural-border text-natural-text-neutral rounded-full\" title=\"Story Points\">\n                                {issue.storyPoints}\n                              </span>\n                            ) : (\n                              <span className=\"text-[10px] text-natural-text-light italic\">No SP</span>\n                            )}\n\n                            <div className=\"flex items-center gap-2\">\n                              {issue.subtasks.length > 0 && (\n                                <span className=\"text-[9px] text-natural-text-light font-bold\" title=\"Sub-task progress\">\n                                  {issue.subtasks.filter(s => s.completed).length}/{issue.subtasks.length} subtasks\n                                </span>\n                              )}\n                              <img\n                                src={issue.assignee.avatar}\n                                alt={issue.assignee.name}\n                                className=\"w-5.5 h-5.5 rounded-full border border-white ring-2 ring-natural-sidebar object-cover\"\n                                title={`Assigned to ${issue.assignee.name}`}\n                                referrerPolicy=\"no-referrer\"\n                              />\n                            </div>\n                          </div>\n\n                          {/* Quick state-selector overlay (visible on hover) for easy access */}\n                          <div className=\"absolute top-2 right-2 o