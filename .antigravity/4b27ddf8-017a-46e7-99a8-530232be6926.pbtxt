option>\n              {SEED_USERS.map((user) => (\n                <option key={user.email} value={user.name}>\n                  {user.name}\n                </option>\n              ))}\n            </select>\n          </div>\n\n          {/* Priority Filter */}\n          <div className=\"flex items-center\">\n            <label className=\"text-[10px] font-bold text-natural-text-light mr-2 uppercase tracking-wider\">Priority:</label>\n            <select\n              value={selectedPriority}\n              onChange={(e) => setSelectedPriority(e.target.value)}\n              className=\"px-3 py-1.5 text-xs bg-white border border-natural-border rounded-xl text-natural-text-deep focus:outline-hidden focus:ring-1 focus:ring-natural-primary cursor-pointer shadow-2xs\"\n            >\n              <option value=\"All\">All Priorities</option>\n              <option value=\"Highest\">Highest</option>\n              <option value=\"High\">High</option>\n              <option value=\"Medium\">Medium</option>\n              <option value=\"Low\">Low</option>\n            </select>\n          </div>\n\n          {hasActiveFilters && (\n            <button\n              onClick={clearAllFilters}\n              className=\"text-xs text-natural-primary hover:text-natural-primary-hover font-bold px-3 py-1.5 rounded-xl hover:bg-natural-hover-bg transition-colors\"\n            >\n              Clear Filters\n            </button>\n          )}\n\n          {/* Issue Counter stats */}\n          <div className=\"ml-auto text-[10px] font-bold uppercase tracking-wider text-natural-text-light bg-natural-sidebar border border-natural-border px-3 py-1.5 rounded-full\">\n            Showing <strong className=\"text-natural-text-deep\">{filteredIssues.length}</strong> of {activeSprintIssues.length} active issues\n          </div>\n        </div>\n      </div>\n\n      {/* Grid of Board Columns */}\n      <div className=\"flex-1 overflow-x-auto p-6 bg-natural-bg\">\n        <div c