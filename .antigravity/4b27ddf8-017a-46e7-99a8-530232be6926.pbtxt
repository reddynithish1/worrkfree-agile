xt-sm text-[#9A978A] flex items-center space-x-2\\\"><span>Projects</span><span class=\\\"opacity-50\\\">/</span><span class=\\\"text-[#43423E] font-medium\\\">Horizon Engine v2.0</span></nav><h1 class=\\\"text-xl font-bold\\\">Board</h1></div><div class=\\\"flex items-center space-x-4\\\"><div class=\\\"relative\\\"><div class=\\\"absolute left-3 top-2.5 w-4 h-4 text-[#9A978A]\\\"><svg fill=\\\"none\\\" stroke=\\\"currentColor\\\" viewBox=\\\"0 0 24 24\\\"><path stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\" stroke-width=\\\"2\\\" d=\\\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\\\"/></svg></div><input type=\\\"text\\\" placeholder=\\\"Search issues...\\\" class=\\\"bg-[#F4F2EB] border border-[#E6E2D3] rounded-full py-2 pl-10 pr-4 text-sm w-64 focus:outline-none focus:ring-1 focus:ring-[#7C8463]\\\"/></div><button class=\\\"bg-[#7C8463] text-white px-5 py-2 rounded-full text-sm font-medium hover:bg-[#686F53]\\\">Create Issue</button></div></header><div class=\\\"flex-1 grid grid-cols-4 gap-6 p-8 overflow-hidden bg-[#FDFCF8]\\\"><section class=\\\"flex flex-col space-y-4\\\"><div class=\\\"flex items-center justify-between px-1\\\"><h2 class=\\\"text-[11px] font-bold uppercase tracking-widest text-[#9A978A]\\\">Backlog <span class=\\\"ml-1 px-1.5 py-0.5 bg-[#F4F2EB] rounded text-[#7A786F]\\\">3</span></h2></div><div class=\\\"space-y-3\\\"><div class=\\\"bg-white p-4 rounded-2xl border border-[#E6E2D3] shadow-sm hover:border-[#D4A373] transition-colors\\\"><div class=\\\"text-xs font-medium text-[#D4A373] mb-2\\\">Enhancement</div><p class=\\\"text-sm font-semibold mb-3\\\">Implement dark mode palette based on natural tones</p><div class=\\\"flex items-center justify-between\\\"><span class=\\\"text-[10px] text-[#9A978A] font-bold\\\">ENG-124</span><div class=\\\"flex -space-x-1\\\"><div class=\\\"w-5 h-5 rounded-full bg-[#E6E2D3] border border-white\\\"></div></div></div></div><div class=\\\"bg-white p-4 rounded-2xl border border-[#E6E2D3] shadow-sm\\\"><div class=\\\"text-xs font-medium text-[#7C8463] mb-2\\\">Feature</div><p class=\\\"text-sm font-semibold mb-3\\\">Update authentication flow for external contractors</p><div class=\\\"flex items-center justify-between\\\"><span class=\\\"text-[10px] text-[#9A978A] font-bold\\\">ENG-118</span><div class=\\\"w-5 h-5 rounded-full bg-[#CCD5AE] border border-white\\\"></div></div></div></div></section><section class=\\\"flex flex-col space-y-4\\\"><div class=\\\"flex items-center justify-between px-1\\\"><h2 class=\\\"text-[11px] font-bold uppercase tracking-widest text-[#9A978A]\\\">In Progress <span class=\\\"ml-1 px-1.5 py-0.5 bg-[#F4F2EB] rounded text-[#7A786F]\\\">2</span></h2></div><div class=\\\"space-y-3\\\"><div class=\\\"bg-white p-4 rounded-2xl border-l-4 border-l-[#D4A373] border-[#E6E2D3] shadow-sm\\\"><div class=\\\"text-xs font-medium text-[#A67C52] mb-2 uppercase tracking-tight font-bold\\\">Urgent</div><p class=\\\"text-sm font-semibold mb-3\\\">Refactor state management in dashboard widget grid</p><div class=\\\"flex items-center justify-between\\\"><span class=\\\"text-[10px] text-[#9A978A] font-bold\\\">ENG-092</span><div class=\\\"w-5 h-5 rounded-full bg-[#FAEDCD] border border-white\\\"></div></div></div><div class=\\\"bg-white p-4 rounded-2xl border border-[#E6E2D3] shadow-sm\\\"><div class=\\\"text-xs font-medium text-[#7C8463] mb-2\\\">Feature</div><p class=\\\"text-sm font-semibold mb-3\\\">Add export to PDF functionality for monthly audits</p><div class=\\\"flex items-center justify-between\\\"><span class=\\\"text-[10px] text-[#9A978A] font-bold\\\">ENG-104</span><div class=\\\"w-5 h-5 rounded-full bg-[#D4A373] border border-white\\\"></div></div></div></div></section><section class=\\\"flex flex-col space-y-4\\\"><div class=\\\"flex items-center justify-between px-1\\\"><h2 class=\\\"text-[11px] font-bold uppercase tracking-widest text-[#9A978A]\\\">Review <span class=\\\"ml-1 px-1.5 py-0.5 bg-[#F4F2EB] rounded text-[#7A786F]\\\">1</span>