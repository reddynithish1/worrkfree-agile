                  {currentProject.key}\n                  </div>\n                  <div className=\"min-w-0\">\n                    <span className=\"block font-semibold text-xs text-natural-text-deep truncate\">{currentProject.name}</span>\n                    <span className=\"block text-[9px] text-natural-text-light tracking-wider font-semibold\">Key: {currentProject.key}</span>\n                  </div>\n                </div>\n\n                {/* Switcher selector */}\n                <select\n                  value={activeProjectId}\n                  onChange={(e) => setActiveProjectId(e.target.value)}\n                  className=\"absolute inset-0 opacity-0 w-full cursor-pointer h-full\"\n                  title=\"Switch Project Workspace\"\n                >\n                  {projects.map((p) => (\n                    <option key={p.id} value={p.id}>\n                      {p.name} ({p.key})\n                    </option>\n                  ))}\n                </select>\n                <ChevronDown className=\"w-4 h-4 text-natural-text-light\" />\n              </div>\n            ) : (\n              <p className=\"text-xs text-natural-text-light px-2\">No projects configured</p>\n            )}\n          </div>\n\n          {/* Tab Navigation items */}\n          <div className=\"space-y-1\">\n            <div className=\"text-[10px] uppercase tracking-widest text-natural-text-light font-bold mb-3 px-2\">Workspace Navigation</div>\n            <nav className=\"space-y-1.5\">\n              <button\n                onClick={() => setActiveTab(\"board\")}\n                className={`w-full flex items-center gap-3 px-3 py-2 text-xs font-bold rounded-xl transition-colors ${\n                  activeTab === \"board\"\n                    ? \"bg-white text-natural-text-deep shadow-xs border border-natural-border\"\n                    : \"text-natural-text-neutral hover:bg-natural-hover-bg hover:text-natural-text-deep\"\n                }`}\n              >\n                <LayoutGrid className={`w-4 h-4 ${activeTab === \"board\" ? \"text-natural-primary\" : \"text-natural-text-light\"}`} />\n                <span>Active Sprint Board</span>\n              </button>\n\n              <button\n                onClick={() => setActiveTab(\"backlog\")}\n                className={`w-full flex items-center gap-3 px-3 py-2 text-xs font-bold rounded-xl transition-colors ${\n                  activeTab === \"backlog\"\n                    ? \"bg-white text-natural-text-deep shadow-xs border border-natural-border\"\n                    : \"text-natural-text-neutral hover:bg-natural-hover-bg hover:text-natural-text-deep\"\n                }`}\n              >\n                <Database className={`w-4 h-4 ${activeTab === \"backlog\" ? \"text-natural-primary\" : \"text-natural-text-light\"}`} />\n                <span>Backlog Planner</span>\n              </button>\n\n              <button\n                onClick={() => setActiveTab(\"copilot\")}\n                className={`w-full flex items-center gap-3 px-3 py-2 text-xs font-bold rounded-xl transition-colors ${\n                  activeTab === \"copilot\"\n                    ? \"bg-white text-natural-text-deep shadow-xs border border-natural-border\"\n                    : \"text-natural-text-neutral hover:bg-natural-hover-bg hover:text-natural-text-deep\"\n                }`}\n              >\n                <Sparkles className={`w-4 h-4 ${activeTab === \"copilot\" ? \"text-amber-600 fill-amber-100\" : \"text-natural-text-light\"}`} />\n                <span>Agile AI Copilot</span>\n              </button>\n\n              <button\n                onClick={() => setActiveTab(\"insights\")}\n                className={`w-full flex items-center gap-3 px-3 py-2 text-xs font-bold rounded-xl transition-colors ${\n                  activeTab === \"insights\"\n                    ? \"bg-white text-natural-text-deep shadow-xs border border-natural-border\"\n                    : \"text-natural-text-neutral hover:bg-natural-hover-bg hover:text-natural-text-deep\"\n                }`}\n              >\n                <BarChart2 className={`w-4 h-4 ${activeTab === \"insights\" ? \"text-natural-primary\" : \"text-natural-text-light\"}`} />\n                <span>Reports & Insights</span>\n              </button>\n            </nav>\n          </div>\n        </div>\n\n        {/* Footer info segment */}\n        <div className=\"flex items-center space-x-3 p-3 bg-white/50 rounded-2xl border border-natural-border\">\n          <img\n            src=\"https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=150\"\n            alt=\"Nithish profile\"\n            className=\"w-8 h-8 rounded-full border-2 border-white object-cover\"\n            referrerPolicy=\"no-referrer\"\n          />\n          <div className=\"min-w-0\">\n            <div className=\"text-xs font-bold text-natural-text-deep\">Nithish Reddy</div>\n            <div className=\"text-[10px] text-natural-text-light font-medium uppercase tracking-wider\">Scrum Master Dev</div>\n          </div>\n        </div>\n\n      </div>\n\n      {/* RIGHT SIDE MAIN WORKSPACE WRAPPER */}\n      <div className=\"flex-1 flex flex-col overflow-hidden relative\">\n        "
